---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Toaster } from '@/components/ui/sonner';
import { PwaManager } from '@/components/organisms/profesor/PwaManager';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Gestioná tu gimnasio sin hojas de cálculo. Planes, alumnos y cobros en un solo lugar.' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		
		<!-- PWA / Mobile Meta -->
		<meta name="theme-color" content="#09090b" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="MiGym" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />

		<!-- Theme Script (Prevent Flash) -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>
	</head>
	<body class="overflow-x-hidden font-sans antialiased bg-background text-foreground">
		<slot />
		<Toaster client:load transition:persist="toaster" />
		<div transition:persist="pwa-manager">
			<PwaManager client:only="react" />
		</div>

		{/* Service Worker Registration */}
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then(reg => console.log('[MiGym] SW registrado:', reg.scope))
						.catch(err => console.error('[MiGym] SW falló:', err));
				});
			}

			// PWA Badging API Support (Industrial Productivity)
			window.setAppBadge = (count) => {
				if ('setAppBadge' in navigator) {
					if (count > 0) navigator.setAppBadge(count);
					else navigator.clearAppBadge();
				}
			};
		</script>
	</body>
</html>
