---
import Layout from "./Layout.astro";
import { Home, User } from "lucide-react";
import { globalCopy } from "../data/es/global";
import { getAuthenticatedClient } from "../lib/supabase-ssr";
import { cn } from "@/lib/utils";
import { AlumnoBottomNav } from "@/components/molecules/alumno/AlumnoBottomNav";

interface Props {
  title: string;
  hideHeader?: boolean;
}

const { title, hideHeader = false } = Astro.props;
const currentPath = Astro.url.pathname;
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

const isGuest = user.role === "invitado";
const supabase = getAuthenticatedClient(Astro);

// Buscamos el perfil del alumno y los datos de su profe
const { data: alumno } = await supabase
  .from("alumnos")
  .select(
    `
    id, 
    nombre, 
    profesor_id, 
    profesores (
      nombre, 
      telefono
    )
  `,
  )
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

if (!alumno) {
  console.error("AlumnoLayout: Alumno no encontrado para el usuario:", user.id);
}

const profTel = (alumno as any)?.profesores?.telefono?.replace(/\D/g, "");
const waLink = profTel ? `https://wa.me/${profTel}` : "#";
---

<Layout title={title}>
  <!-- INDUSTRIAL DARK WRAPPER -->
  <div class="min-h-screen bg-black text-white font-sans selection:bg-lime-400 selection:text-black">
    
    <!-- BANNER DE INVITADO (Aesthetics Industrial) -->
    <!-- {
      isGuest && (
        <div class="bg-zinc-950 text-white px-4 py-2 flex items-center justify-between gap-4 border-b border-white/10 sticky top-0 z-50 overflow-hidden">
          <div class="absolute inset-0 bg-lime-500/5 mix-blend-overlay pointer-events-none" />
          <div class="flex items-center gap-2 relative z-10">
            <div class="w-2 h-2 rounded-full bg-lime-500 animate-pulse" />
            <span class="text-[9px] font-bold uppercase tracking-[0.2em]">
              Modo Invitado Activo
            </span>
          </div>
          <a
            href="/login"
            class="relative z-10 bg-lime-400 text-black px-3 py-1 rounded-lg text-[9px] font-bold uppercase tracking-widest hover:scale-105 transition-transform active:scale-95 shadow-[0_0_15px_rgba(163,230,53,0.3)]"
          >
            Asegurar Historial
          </a>
        </div>
      )
    } -->

    { !hideHeader && (
      <header
        class={cn(
          "bg-black/60 backdrop-blur-2xl border-b border-white/5 p-4 sticky z-40 flex justify-between items-center md:px-8",
          isGuest ? "top-0" : "top-0"
        )}
      >
        <div class="flex items-center gap-2">
          <span class="font-black text-xl tracking-tighter uppercase text-white">
            {globalCopy.brand.nameLine1}<span class="text-lime-400">{globalCopy.brand.nameHighlight}</span>
          </span>
        </div>
        <a
          href="/alumno/perfil"
          class="w-10 h-10 rounded-2xl bg-zinc-900/50 border border-white/5 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white/20 transition-all active:scale-95"
        >
          <User className="w-5 h-5" />
        </a>
      </header>
    )}

    <!-- Main Content with Max Width for Phone Layout -->
    <main class="flex-1 p-4 md:p-8 max-w-lg mx-auto md:max-w-4xl min-h-[calc(100vh-140px)]">
      <slot />
    </main>

    <!-- Bottom Navigation (Mobile) -->
    <AlumnoBottomNav currentPath={currentPath} client:load />
    
  </div>
</Layout>

<style is:global>
  /* Safe area for mobile keyboards and iPhone notches */
  nav {
    margin-bottom: env(safe-area-inset-bottom, 0);
  }

  /* Industrial Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #000;
  }
  ::-webkit-scrollbar-thumb {
    background: #27272a;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #3f3f46;
  }
</style>
