---
import Layout from './Layout.astro';
import { 
  LayoutDashboard, 
  ClipboardList, 
  Users, 
  Dumbbell, 
  CreditCard, 
  Settings,
  LogOut,
  Bell,
  Search
} from 'lucide-react';

import { globalCopy } from '../data/es/global';
import { dashboardCopy } from '../data/es/profesor/dashboard';
import { createSupabaseServerClient } from '../lib/supabase-ssr';
import { MobileNav } from '../components/organisms/profesor/MobileNav';
import { NotificationDropdown } from '../components/organisms/profesor/NotificationDropdown';
import { UserAccountMenu } from '../components/organisms/profesor/UserAccountMenu';
import { UniversalSearch } from '../components/organisms/profesor/UniversalSearch';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

const supabase = createSupabaseServerClient(Astro);
const { data: profesor } = await supabase
  .from("profesores")
  .select("nombre, foto_url, slug")
  .eq("id", user.id)
  .single();

if (!profesor) {
  // Defensa secundaria: El middleware ya deberÃ­a haber filtrado esto,
  // pero si el registro de profesor desapareciÃ³ o hubo un error, rebotamos.
  return Astro.redirect("/onboarding");
}

const safeProfesor = {
  nombre: profesor.nombre || "Entrenador",
  foto_url: profesor.foto_url || null,
  slug: profesor.slug || null,
};

// Mock navigation items
const navItems = [
  { name: globalCopy.layout.profesorNav.dashboard, href: '/profesor', icon: LayoutDashboard },
  { name: globalCopy.layout.profesorNav.planes, href: '/profesor/planes', icon: ClipboardList },
  { name: globalCopy.layout.profesorNav.alumnos, href: '/profesor/alumnos', icon: Users },
  { name: globalCopy.layout.profesorNav.ejercicios, href: '/profesor/ejercicios', icon: Dumbbell },
  { name: globalCopy.layout.profesorNav.pagos, href: '/profesor/pagos', icon: CreditCard },
];

const currentPath = Astro.url.pathname;
---

<Layout title={title}>
  <div class="flex min-h-screen bg-zinc-50/50">
    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex flex-col w-64 bg-white border-r border-zinc-200 fixed h-full z-20">
      <div class="h-16 flex items-center px-6 border-b border-zinc-200">
        <a href="/profesor" class="font-black text-2xl tracking-tighter flex items-center hover:opacity-80 transition-opacity">
          {globalCopy.brand.nameLine1}<span class="text-lime-500">{globalCopy.brand.nameHighlight}</span>
          <span class="ml-1.5 px-1.5 py-0.5 rounded bg-zinc-950 text-white text-[10px] uppercase tracking-widest font-extrabold">{globalCopy.brand.proBadge}</span>
        </a>
      </div>
      
      <nav class="flex-1 p-4 space-y-1">
        {navItems.map((item) => {
          const Icon = item.icon;
          const isActive = currentPath === item.href || (item.href !== '/profesor' && currentPath.startsWith(item.href));
          
          return (
            <a 
              href={item.href} 
              class={`flex items-center gap-3 px-3 py-2.5 rounded-2xl transition-all duration-200 group ${
                isActive 
                  ? 'bg-zinc-950 text-white shadow-lg shadow-zinc-200' 
                  : 'text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900'
              }`}
            >
              <Icon className={`w-5 h-5 ${isActive ? 'text-lime-400' : 'group-hover:text-zinc-900'}`} aria-hidden="true" />
              <span class="text-sm font-bold uppercase tracking-wide">{item.name}</span>
            </a>
          );
        })}
      </nav>

      <div class="px-6 py-6 border-t border-zinc-100 italic text-[10px] text-zinc-400 uppercase tracking-widest font-bold">
        {globalCopy.brand.nameLine1}{globalCopy.brand.nameHighlight} v1.0
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 md:pl-64 flex flex-col min-h-screen">
      <!-- Top Header -->
      <header class="h-16 bg-white/80 backdrop-blur-md border-b border-zinc-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-30 gap-2 md:gap-4">
        
        <!-- Left Section (Logo/Title) - Hidden when search expanded on mobile -->
        <div class="flex items-center gap-4 shrink-0 transition-all duration-300 has-[+div_.is-search-expanded]:w-0 has-[+div_.is-search-expanded]:opacity-0 overflow-hidden">
            <!-- Mobile Left -->
            <div class="flex items-center gap-2 md:hidden">
                <MobileNav client:load currentPath={currentPath} />
                <a href="/profesor" class="font-black text-xl tracking-tighter shrink-0">
                  {globalCopy.brand.nameLine1}<span class="text-lime-500">{globalCopy.brand.nameHighlight}</span>
                </a>
            </div>
        </div>

        <!-- Middle Section (Search) -->
        <div class="flex-1 flex justify-end md:justify-start">
            <UniversalSearch client:load />
        </div>

        <!-- Right Actions -->
        <div class="flex items-center gap-3 shrink-0 transition-all duration-300 has-[:hover]:scale-105">
          <NotificationDropdown client:load />
          <div class="h-8 w-[1px] bg-zinc-200 mx-1"></div>
          <UserAccountMenu client:load profesor={safeProfesor} />
        </div>
      </header>
      
      <main class="flex-1 p-4 md:p-8">
        <slot />
      </main>
    </div>
  </div>
</Layout>
