---
/**
 * Molecule: LandingNavbar
 * Header mínimo para la landing. Transparente por defecto,
 * se torna sólido al hacer scroll (JS inline, sin dependencias extra).
 * Copy centralizado en landingCopy.navbar.
 */
import { landingCopy } from '../../../data/es/landing';
import { Zap } from 'lucide-react';

const { navbar } = landingCopy;
---

<header
  id="landing-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-5 md:px-8"
  aria-label="Navegación principal"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-black text-xl tracking-tighter text-zinc-950" aria-label="Ir al inicio de MiGym">
      {navbar.logoPrefix}<span class="text-lime-500">{navbar.logoSuffix}</span>
    </a>

    <!-- Acciones -->
    <nav class="flex items-center gap-3" aria-label="Acciones de cuenta">
      <a
        href="/login"
        class="hidden sm:inline-flex items-center px-5 h-10 text-sm font-bold text-zinc-600 hover:text-zinc-950 transition-colors rounded-xl hover:bg-zinc-100"
      >
        {navbar.linkLogin}
      </a>
      <a
        href="/login"
        id="nav-cta"
        class="inline-flex items-center gap-2 px-5 h-10 bg-zinc-950 text-white font-black text-sm rounded-xl transition-all hover:bg-zinc-800 active:scale-95 uppercase tracking-wide"
      >
        <Zap className="w-3.5 h-3.5 text-lime-400" aria-hidden="true" />
        {navbar.ctaPrimary}
      </a>
    </nav>
  </div>
</header>

<!-- Espaciador para que el contenido no quede bajo el nav fixed -->
<div class="h-[72px]" aria-hidden="true"></div>

<script is:inline>
  (function () {
    const nav = document.getElementById('landing-nav');
    if (!nav) return;

    function updateNav() {
      if (window.scrollY > 24) {
        nav.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-zinc-100');
        nav.classList.remove('py-4');
        nav.classList.add('py-2.5');
      } else {
        nav.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-zinc-100');
        nav.classList.remove('py-2.5');
        nav.classList.add('py-4');
      }
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  })();
</script>
