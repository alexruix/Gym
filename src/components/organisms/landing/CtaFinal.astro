---
import { landingCopy } from '../../../data/es/landing';
import { ArrowRight, Users } from 'lucide-react';

const { ctaFinal } = landingCopy;
---

<section class="py-28 px-5 md:px-8 bg-zinc-950 relative overflow-hidden">
    <!-- Fondo: glow de acento -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-lime-400/10 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Grid decorativo -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(163,230,53,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(163,230,53,0.03)_1px,transparent_1px)] bg-[size:80px_80px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10 space-y-8 animate-in fade-in duration-700">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-lime-400/10 border border-lime-400/20 text-lime-400 font-black text-[10px] uppercase tracking-widest">
            <Users className="w-3 h-3" aria-hidden="true" />
            {ctaFinal.badge}
        </div>

        <!-- Título -->
        <h2 class="text-5xl md:text-7xl font-black tracking-tighter text-white leading-[0.9]">
            {ctaFinal.title}<br/>
            <span class="text-lime-400 italic">{ctaFinal.titleHighlight}</span>
        </h2>

        <!-- Descripción -->
        <p class="text-lg md:text-xl text-zinc-400 font-medium max-w-2xl mx-auto leading-relaxed">
            {ctaFinal.description}
        </p>

        <!-- CTA -->
        <div class="flex flex-col items-center gap-3 pt-4">
            <a
                href="/login"
                class="group inline-flex w-full sm:w-auto items-center justify-center gap-3 px-10 h-16 bg-lime-400 text-zinc-950 font-black rounded-2xl transition-all hover:bg-lime-300 hover:shadow-2xl hover:shadow-lime-400/30 hover:scale-105 active:scale-95 text-lg uppercase tracking-wider"
            >
                {ctaFinal.cta}
                <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" aria-hidden="true" />
            </a>
            <p class="text-xs text-zinc-500 font-medium">{ctaFinal.ctaSub}</p>
        </div>

    </div>
</section>
