---
import { landingCopy } from '../../../data/es/landing';
import LandingSectionBadge from '../../atoms/landing/LandingSectionBadge.astro';
import { formatCurrency } from '../../../lib/utils';
import { Check, Zap, ShieldCheck } from 'lucide-react';

const { pricing } = landingCopy;
---

<section class="py-24 px-5 md:px-8 bg-zinc-50 relative overflow-hidden" aria-label="Precio y plan">
    <!-- Decoraciones de fondo -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent" aria-hidden="true"></div>
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-lime-400/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto relative z-10">

        <!-- Header -->
        <div class="text-center max-w-2xl mx-auto mb-16 space-y-3 animate-in fade-in duration-500">
            <LandingSectionBadge text={pricing.badge} variant="light" />
            <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-zinc-950 leading-tight">
                {pricing.title} <span class="text-lime-500 italic">{pricing.titleHighlight}</span>
            </h2>
        </div>

        <!-- Card centrada -->
        <div class="max-w-lg mx-auto">
            <div class="relative">

                <!-- Glow del card -->
                <div class="absolute -inset-3 bg-lime-400/20 rounded-[3rem] blur-2xl" aria-hidden="true"></div>

                <!-- Card principal -->
                <div class="relative bg-white border-2 border-zinc-200 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-zinc-950/10">

                    <!-- Badge "El más elegido" -->
                    <div class="bg-lime-400 py-3 px-6 flex items-center justify-center gap-2">
                        <Zap className="w-4 h-4 text-zinc-950" aria-hidden="true" />
                        <span class="font-black text-sm text-zinc-950 uppercase tracking-widest">El más elegido</span>
                    </div>

                    <div class="p-8 md:p-10">

                        <!-- Precio + trial -->
                        <div class="text-center mb-8">
                            <div class="flex items-end justify-center gap-2">
                                <span class="text-5xl md:text-6xl font-black tracking-tighter text-zinc-950 leading-none">
                                    {formatCurrency(pricing.price)}
                                </span>
                                <span class="text-zinc-400 font-bold text-lg pb-1">{pricing.period}</span>
                            </div>
                            <div class="mt-3 inline-flex items-center gap-2 bg-lime-50 border border-lime-200 rounded-full px-4 py-1.5">
                                <span class="w-2 h-2 rounded-full bg-lime-500 animate-pulse" aria-hidden="true"></span>
                                <span class="text-lime-700 font-black text-xs uppercase tracking-wider">{pricing.trial}</span>
                            </div>
                        </div>

                        <!-- Lista de features -->
                        <ul class="space-y-3.5 mb-8" aria-label="Qué incluye el plan">
                            {pricing.features.map((feature) => (
                                <li class="flex items-start gap-3">
                                    <div class="w-5 h-5 rounded-full bg-lime-100 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
                                        <Check className="w-3 h-3 text-lime-600" aria-hidden="true" />
                                    </div>
                                    <span class="text-zinc-700 font-medium text-sm leading-snug">{feature}</span>
                                </li>
                            ))}
                        </ul>

                        <!-- CTA -->
                        <a
                            href="/login"
                            id="pricing-cta"
                            class="w-full h-14 flex items-center justify-center bg-zinc-950 text-white font-black rounded-2xl transition-all hover:bg-zinc-800 hover:shadow-xl active:scale-95 text-base uppercase tracking-wider mb-3"
                        >
                            {pricing.cta}
                        </a>
                        <p class="text-center text-xs text-zinc-400 font-medium">{pricing.ctaSub}</p>
                    </div>

                    <!-- Guarantee footer -->
                    <div class="border-t border-zinc-100 px-8 py-5 bg-zinc-50 flex items-center gap-3">
                        <ShieldCheck className="w-5 h-5 text-zinc-400 shrink-0" aria-hidden="true" />
                        <p class="text-xs text-zinc-500 font-medium">{pricing.guarantee}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
