---
import { landingCopy } from '../../../data/es/landing';
import { Zap, Play, Users, Clock, TrendingUp, Star } from 'lucide-react';

const { hero, stats } = landingCopy;
---

<section class="relative pt-20 pb-0 overflow-hidden bg-white">
    <!-- Background decorativo -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(163,230,53,0.12),rgba(255,255,255,0))]"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-zinc-50 clip-hero hidden lg:block"></div>

    <div class="max-w-7xl mx-auto px-5 md:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center min-h-[85vh] pb-12">

            <!-- Columna Izquierda: Copy -->
            <div class="flex flex-col gap-6 pt-8 lg:pt-0 animate-in fade-in slide-in-from-bottom-6 duration-700">

                <!-- Badge -->
                <div class="inline-flex items-center gap-2 self-start px-4 py-2 rounded-full bg-lime-50 border border-lime-200 text-lime-700 font-black text-[10px] uppercase tracking-widest">
                    <span class="w-1.5 h-1.5 rounded-full bg-lime-500 animate-pulse"></span>
                    {hero.badge}
                </div>

                <!-- Título -->
                <h1 class="text-5xl md:text-6xl xl:text-7xl font-black tracking-tighter leading-[0.9] text-zinc-950">
                    {hero.titleLine1}<br/>
                    <span class="relative">
                        <span class="relative z-10 text-lime-500 italic">{hero.titleHighlight}</span>
                        <span class="absolute bottom-1 left-0 w-full h-3 bg-lime-100 -z-10 skew-x-1"></span>
                    </span>
                </h1>

                <!-- Descripción -->
                <p class="text-lg md:text-xl text-zinc-500 font-medium leading-relaxed max-w-lg">
                    {hero.description}
                </p>

                <!-- CTAs -->
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 pt-2">
                    <a
                        href="/login"
                        class="group flex items-center justify-center gap-2 px-8 h-14 bg-zinc-950 text-white font-black rounded-2xl transition-all hover:bg-zinc-800 hover:shadow-2xl hover:shadow-zinc-950/20 active:scale-95 text-base uppercase tracking-wider"
                    >
                        <Zap className="w-4 h-4 text-lime-400 group-hover:scale-110 transition-transform" aria-hidden="true" />
                        {hero.ctaPrimary}
                    </a>
                    <a
                        href="#demo"
                        class="group flex items-center justify-center gap-2 px-8 h-14 border-2 border-zinc-200 bg-white text-zinc-700 font-black rounded-2xl transition-all hover:border-zinc-300 hover:bg-zinc-50 active:scale-95 text-base uppercase tracking-wider"
                    >
                        <span class="w-8 h-8 rounded-full bg-zinc-100 flex items-center justify-center group-hover:bg-lime-100 transition-colors">
                            <Play className="w-3 h-3 text-zinc-700 group-hover:text-lime-600 transition-colors ml-0.5" aria-hidden="true" />
                        </span>
                        {hero.ctaSecondary}
                    </a>
                </div>

                <!-- Social hint -->
                <div class="flex items-center gap-2 text-sm text-zinc-400 font-medium">
                    <div class="flex -space-x-2">
                        {["M", "L", "D", "A", "R"].map((initial) => (
                            <div class="w-7 h-7 rounded-full bg-zinc-200 border-2 border-white flex items-center justify-center text-[10px] font-black text-zinc-600">
                                {initial}
                            </div>
                        ))}
                    </div>
                    <span>{hero.socialHint}</span>
                </div>
            </div>

            <!-- Columna Derecha: Mockup del producto -->
            <div class="relative animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
                <!-- Glow de fondo -->
                <div class="absolute -inset-8 bg-lime-400/10 rounded-[3rem] blur-3xl"></div>

                <!-- Mockup Card (dashboard simulado) -->
                <div class="relative bg-zinc-950 rounded-[2rem] p-1 shadow-2xl shadow-zinc-950/30 border border-zinc-800">
                    <!-- Barra de navegación del mockup -->
                    <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
                            <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
                            <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
                        </div>
                        <div class="flex-1 h-5 rounded bg-zinc-800 mx-4 flex items-center px-3">
                            <span class="text-[9px] text-zinc-500 font-mono">app.migym.ar/profesor</span>
                        </div>
                    </div>

                    <!-- Contenido del dashboard mockup -->
                    <div class="p-4 space-y-3">
                        <!-- Header del dashboard -->
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest">Buenos días,</p>
                                <p class="text-white font-black text-base">Marcos Trainer</p>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-lime-400 flex items-center justify-center text-zinc-950 font-black text-sm">M</div>
                        </div>

                        <!-- Stats cards del dashboard -->
                        <div class="grid grid-cols-3 gap-2">
                            {[
                                { icon: Users, label: "Alumnos", value: "48", color: "text-lime-400" },
                                { icon: Clock, label: "Vencen hoy", value: "3", color: "text-amber-400" },
                                { icon: TrendingUp, label: "Este mes", value: "$0", color: "text-emerald-400" },
                            ].map(({ icon: Icon, label, value, color }) => (
                                <div class="bg-zinc-900 rounded-xl p-2.5 border border-zinc-800">
                                    <Icon className={`w-3.5 h-3.5 ${color} mb-1`} aria-hidden="true" />
                                    <p class={`text-lg font-black ${color} leading-none`}>{value}</p>
                                    <p class="text-[9px] text-zinc-500 font-bold mt-0.5 uppercase tracking-wide">{label}</p>
                                </div>
                            ))}
                        </div>

                        <!-- Lista de alumnos simulada -->
                        <div class="bg-zinc-900 rounded-xl p-3 border border-zinc-800">
                            <p class="text-[9px] text-zinc-500 font-black uppercase tracking-widest mb-2">Alumnos recientes</p>
                            {[
                                { name: "Ana González", plan: "3 días/sem", status: "Al día", ok: true },
                                { name: "Juan López", plan: "Full body", status: "Vence hoy", ok: false },
                                { name: "María Sosa", plan: "Funcional", status: "Al día", ok: true },
                            ].map(({ name, plan, status, ok }) => (
                                <div class="flex items-center justify-between py-1.5 border-b border-zinc-800 last:border-0">
                                    <div class="flex items-center gap-2">
                                        <div class="w-5 h-5 rounded-full bg-zinc-700 flex items-center justify-center text-[8px] font-black text-zinc-300">
                                            {name.charAt(0)}
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-zinc-200">{name}</p>
                                            <p class="text-[8px] text-zinc-500">{plan}</p>
                                        </div>
                                    </div>
                                    <span class={`text-[8px] font-black px-2 py-0.5 rounded-full ${ok ? 'bg-emerald-400/10 text-emerald-400' : 'bg-amber-400/10 text-amber-400'}`}>
                                        {status}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>

                <!-- Badge flotante -->
                <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl px-4 py-3 shadow-xl shadow-zinc-950/10 border border-zinc-100 flex items-center gap-3 animate-in fade-in slide-in-from-bottom-2 duration-700 delay-500">
                    <div class="w-10 h-10 rounded-xl bg-lime-400 flex items-center justify-center">
                        <Star className="w-5 h-5 text-zinc-950" aria-hidden="true" />
                    </div>
                    <div>
                        <p class="text-xs font-black text-zinc-950">500+ profesores</p>
                        <p class="text-[10px] text-zinc-400 font-medium">Confían en MiGym</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Barra de Stats -->
        <div class="border-t border-zinc-100 py-10 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-zinc-100 animate-in fade-in duration-700 delay-300">
            {stats.map((stat) => (
                <div class="text-center md:px-8 space-y-1">
                    <p class="text-3xl md:text-4xl font-black text-zinc-950 tracking-tighter">{stat.value}</p>
                    <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest">{stat.label}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .clip-hero {
        clip-path: polygon(10% 0, 100% 0, 100% 100%, 0% 100%);
    }
</style>
