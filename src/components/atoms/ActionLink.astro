---
import { cn } from "@/lib/utils";

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'glow';
  class?: string;
  uppercase?: boolean;
}

const { href, variant = 'primary', class: className, uppercase = false } = Astro.props;

const baseClasses = "inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-2xl font-bold transition-all active:scale-95 text-center";

const variantClasses = {
  primary: "bg-lime-400 text-zinc-950 hover:bg-lime-500 shadow-sm",
  secondary: "bg-white border border-zinc-200 text-zinc-950 hover:-translate-y-0.5 hover:shadow-md shadow-sm",
  glow: "bg-zinc-950 text-lime-400 shadow-xl hover:shadow-2xl hover:shadow-lime-500/20 hover:-translate-y-0.5",
};

const textStyle = uppercase ? "uppercase tracking-widest font-black text-[11px] md:text-xs" : "text-sm";
---

<a href={href} class={cn(baseClasses, variantClasses[variant], textStyle, className)}>
  <slot />
</a>
