---
import { ChevronRight } from "lucide-react";

interface Props {
  items: { 
    label: string; 
    href?: string;
  }[];
  className?: string;
}

const { items, className } = Astro.props;
---

<nav aria-label="Breadcrumb" class:list={["mb-4", className]}>
  <ol class="flex flex-wrap items-center gap-2 text-xs font-medium tracking-widest uppercase text-zinc-500 dark:text-zinc-400">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && (
          <ChevronRight 
            className="w-3 h-3 mx-1 text-zinc-400 dark:text-zinc-600 shrink-0" 
            aria-hidden="true" 
          />
        )}
        {item.href ? (
          <a
            href={item.href}
            class="hover:text-lime-500 transition-colors duration-200"
          >
            {item.label}
          </a>
        ) : (
          <span class="text-zinc-900 dark:text-zinc-100 font-bold">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
