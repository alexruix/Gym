---
import Layout from "../layouts/Layout.astro";
import { WifiOff, Home, RefreshCw } from "lucide-react";
import { Button } from "@/components/ui/button";
---

<Layout title="Sin Conexión | MiGym">
  <main class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center p-6 text-center">
    
    {/* Industrial Shell */}
    <div class="relative group mb-12">
      <div class="absolute -inset-8 bg-lime-500/20 rounded-full blur-3xl opacity-20 group-hover:opacity-40 transition-opacity animate-pulse" />
      <div class="relative w-32 h-32 bg-zinc-900 border border-zinc-800 rounded-[2.5rem] flex items-center justify-center shadow-2xl overflow-hidden">
        <WifiOff className="w-12 h-12 text-zinc-500" />
        {/* Decorative Grid Line */}
        <div class="absolute inset-0 grid grid-cols-4 opacity-10 pointer-events-none">
          <div class="border-r border-zinc-700 h-full" />
          <div class="border-r border-zinc-700 h-full" />
          <div class="border-r border-zinc-700 h-full" />
        </div>
      </div>
    </div>

    <div class="max-w-xs space-y-6">
      <div class="space-y-2">
        <h1 class="text-2xl font-black text-zinc-100 uppercase tracking-tighter sm:text-3xl">
          Sin señal
        </h1>
        <p class="text-zinc-500 font-medium leading-relaxed">
          Estás trabajando en modo local. Los cambios se sincronizarán en cuanto recuperes la conexión.
        </p>
      </div>

      <div class="pt-8 flex flex-col gap-3">
        <Button 
          variant="outline" 
          className="h-14 rounded-2xl border-zinc-800 bg-zinc-900 text-zinc-100 font-bold uppercase text-[10px] tracking-[0.2em] gap-3 hover:bg-zinc-800 hover:text-white transition-all shadow-xl group"
          id="retry-button"
        >
          <RefreshCw className="w-4 h-4 group-active:rotate-180 transition-transform duration-500" />
          Reintentar ahora
        </Button>
        
        <a 
          href="/profesor" 
          class="h-14 rounded-2xl bg-zinc-100 text-zinc-950 flex items-center justify-center font-bold uppercase text-[10px] tracking-[0.2em] gap-3 hover:bg-white transition-all shadow-xl"
        >
          <Home className="w-4 h-4" />
          Ir al Inicio
        </a>
      </div>
    </div>

    {/* Footer Deco */}
    <div class="fixed bottom-12 left-0 right-0 flex justify-center opacity-20">
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-zinc-600">
        MiGym Industrial System / 2026
      </p>
    </div>
  </main>
</Layout>

<script>
  /**
   * Auto-refresh check
   */
  window.addEventListener('online', () => {
    window.location.reload();
  });

  document.getElementById('retry-button')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>
