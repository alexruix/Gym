---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Casi listo - MiGym">
  <main class="min-h-screen flex flex-col items-center justify-center p-6 text-center space-y-6">
    <div class="bg-primary/10 p-6 rounded-full text-5xl">📩</div>
    <h1 class="text-3xl font-bold">Revisá tu email</h1>
    <p class="text-muted-foreground max-w-xs">Te enviamos un link mágico de acceso. Hacé click en el botón del mail para entrar.</p>
    <a href="/login" class="text-primary font-bold hover:underline">Volver a intentar</a>
  </main>
</Layout>
