---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { ImportExercisesModal } from "@/components/organisms/profesor/ejercicios/ImportExercisesModal";
import { exerciseLibraryCopy } from "@/data/es/profesor/ejercicios";
import { MoveLeft, FileSpreadsheet } from "lucide-react";

---

<ProfesorLayout title={`Importar Ejercicios | MiGym`}>
  <div class="px-4 py-6 md:py-10 max-w-4xl mx-auto space-y-8">
    <a 
      href="/profesor/ejercicios" 
      class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-zinc-500 hover:text-lime-500 transition-colors"
    >
      <MoveLeft className="w-4 h-4" />
      Volver a la biblioteca
    </a>

    <header class="space-y-1">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 flex items-center gap-3">
        <FileSpreadsheet className="w-8 h-8 text-lime-500" />
        {exerciseLibraryCopy.import.title}
      </h1>
      <p class="text-base text-zinc-500 dark:text-zinc-400">
        {exerciseLibraryCopy.import.description}
      </p>
    </header>

    <div class="bg-white dark:bg-zinc-950/50 p-6 sm:p-10 rounded-3xl border border-zinc-200 dark:border-zinc-800 shadow-sm min-h-[400px] flex items-center justify-center">
      <ImportExercisesModal client:load isOpen={true} onOpenChange={() => {}} onSuccess={() => {}} />
    </div>
  </div>
</ProfesorLayout>
