---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { ExerciseForm } from "@/components/molecules/profesor/ejercicios/ExerciseForm";
import { exerciseLibraryCopy } from "@/data/es/profesor/ejercicios";
import CreationHeader from "@/components/molecules/profesor/CreationHeader.astro";
import FormContainer from "@/components/molecules/profesor/FormContainer.astro";

const user = Astro.locals.user;
const userId = user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

import { actions } from "astro:actions";
const { data: rawExercises } = await Astro.callAction(actions.profesor.getExerciseLibrary, {});
const exercises = (rawExercises || []) as any[];

// Extraer categorías únicas para el selector
const existingTags = Array.from(new Set((exercises || []).flatMap(ex => ex.tags || []))).sort();

// Ejercicios que pueden ser padres (base)
const mainExercises = (exercises || []).filter(ex => !ex.parent_id);
---

<ProfesorLayout title={`${exerciseLibraryCopy.form.title} | MiGym`}>
  <div class="px-4 py-8 md:py-12 max-w-7xl mx-auto space-y-12">
    <CreationHeader 
      title={exerciseLibraryCopy.form.title}
      subtitle={exerciseLibraryCopy.form.description}
      backHref="/profesor/ejercicios"
      backLabel="Biblioteca de ejercicios"
    />

    <FormContainer size="sm">
      <ExerciseForm 
        client:load 
        successHref="/profesor/ejercicios" 
        cancelHref="/profesor/ejercicios"
        existingTags={existingTags}
        parents={mainExercises}
      />
    </FormContainer>
  </div>
</ProfesorLayout>
