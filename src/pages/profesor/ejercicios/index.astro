---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import ActionLink from "@/components/atoms/ActionLink.astro";
import { ExerciseLibrary } from "@/components/organisms/profesor/ejercicios/ExerciseLibrary";
import { exerciseLibraryCopy } from "@/data/es/profesor/ejercicios";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";

const supabase = createSupabaseServerClient(Astro);
const { data: userData } = await supabase.auth.getUser();
const userId = userData.user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

// Fetch existing exercises from DB
const { data: exercises, error } = await supabase
  .from("biblioteca_ejercicios")
  .select("id, nombre, descripcion, media_url, tags, parent_id, is_template_base, created_at")
  .eq("profesor_id", userId)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando ejercicios:", error);
}
---

<ProfesorLayout title={`${exerciseLibraryCopy.header.title} | MiGym`}>
  <div class="px-4 py-6 md:py-10 max-w-7xl mx-auto space-y-8">
    <PageHeader 
      title={exerciseLibraryCopy.header.title} 
      subtitle={exerciseLibraryCopy.header.subtitle}
      breadcrumbs={[
        { label: "Inicio", href: "/profesor" },
        { label: "Ejercicios" }
      ]}
    >
      <ActionLink href="/profesor/ejercicios/import" variant="secondary" class="flex-1 md:flex-none">
        Importar Excel
      </ActionLink>
      <ActionLink href="/profesor/ejercicios/new" variant="primary" uppercase class="flex-1 md:flex-none">
        {exerciseLibraryCopy.list.action}
      </ActionLink>
    </PageHeader>

    <div class="bg-transparent rounded-2xl">
      <ExerciseLibrary client:load initialExercises={exercises || []} />
    </div>
  </div>
</ProfesorLayout>
