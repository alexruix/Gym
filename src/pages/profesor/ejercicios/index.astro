---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import { ExerciseLibrary } from "@/components/organisms/profesor/ejercicios/ExerciseLibrary";
import { exerciseLibraryCopy } from "@/data/es/profesor/ejercicios";

// El middleware ya validó la sesión y la inyectó en locals — sin round-trip extra.
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

import { actions } from "astro:actions";

const { data: exercises, error } = await Astro.callAction(actions.ejercicios.getExerciseLibrary, {});

if (error) {
  console.error("Error cargando ejercicios:", error);
}

const mappedExercises = exercises || [];
---

<ProfesorLayout title={`${exerciseLibraryCopy.header.title} | MiGym`}>
  <div class="px-4 py-6 md:py-10 max-w-7xl mx-auto space-y-8">
    <PageHeader 
      title={exerciseLibraryCopy.header.title} 
      subtitle={exerciseLibraryCopy.header.subtitle}
      breadcrumbs={[
        { label: "Inicio", href: "/profesor" },
        { label: "Ejercicios" }
      ]}
    />

    <div class="bg-transparent rounded-2xl">
      <ExerciseLibrary client:load initialExercises={mappedExercises} />
    </div>
  </div>
</ProfesorLayout>
