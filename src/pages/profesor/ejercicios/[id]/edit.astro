---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { ExerciseForm } from "@/components/molecules/profesor/ejercicios/ExerciseForm";
import { exerciseLibraryCopy } from "@/data/es/profesor/ejercicios";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import CreationHeader from "@/components/molecules/profesor/CreationHeader.astro";
import FormContainer from "@/components/molecules/profesor/FormContainer.astro";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);
const { data: userData } = await supabase.auth.getUser();
const userId = userData.user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

// Fetch exercise data to pre-fill the form
const { data: exercise, error } = await supabase
  .from("biblioteca_ejercicios")
  .select("*")
  .eq("id", id)
  .or(`profesor_id.eq.${userId},profesor_id.is.null`)
  .single();

if (error || !exercise) {
  console.error("Ejercicio no encontrado:", error);
  return Astro.redirect("/profesor/ejercicios");
}

// Cast para evitar 'never' del tipado inferido por Supabase en selects con .single()
const exerciseData = exercise as any;

// Fetch existing variants if it's a base exercise
let existingVariants = [];
if (!exerciseData.parent_id) {
  const { data: variants } = await supabase
    .from("biblioteca_ejercicios")
    .select("id, nombre")
    .eq("parent_id", exerciseData.id)
    .or(`profesor_id.eq.${userId},profesor_id.is.null`);
  
  existingVariants = variants || [];
}

const initialValues = {
  ...exerciseData,
  existing_variants: existingVariants
};

import { actions } from "astro:actions";
const { data: exercises } = await Astro.callAction(actions.profesor.getExerciseLibrary, {});
const existingTags = Array.from(new Set(((exercises || []) as any[]).flatMap(ex => ex.tags || []))).sort() as string[];
const mainExercises = (exercises || []).filter(ex => !ex.parent_id);

const title = `Editar ${exerciseData.nombre} | MiGym`;
---

<ProfesorLayout title={title}>
  <div class="px-4 py-8 md:py-12 max-w-7xl mx-auto space-y-12">
    <CreationHeader 
      title="Editar ejercicio"
      subtitle="Modificá los detalles del ejercicio, sus categorías y contenido multimedia."
      backHref="/profesor/ejercicios"
      backLabel="Volver a ejercicios"
    />

    <FormContainer size="sm">
      <ExerciseForm 
        client:load 
        initialValues={initialValues} 
        successHref="/profesor/ejercicios" 
        cancelHref="/profesor/ejercicios"
        existingTags={existingTags}
        parents={mainExercises}
      />
    </FormContainer>
  </div>
</ProfesorLayout>
