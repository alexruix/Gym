---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import { TablaPagos } from "@/components/organisms/TablaPagos";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { getAlumnosConPagoActivo } from "@/lib/data-pagos";
import { pagosCopy } from "@/data/es/profesor/pagos";

const supabase = createSupabaseServerClient(Astro);
const { data: userData } = await supabase.auth.getUser();
const userId = userData.user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

let alumnosPagos = [];
let subscriptions = [];
try {
  alumnosPagos = await getAlumnosConPagoActivo(supabase, userId);
  
  const { data: subs } = await supabase
    .from("suscripciones")
    .select("*")
    .eq("profesor_id", userId)
    .order("cantidad_dias", { ascending: true });
    
  subscriptions = subs || [];
  
  // Si no hay suscripciones, inicializamos las de defecto
  if (subscriptions.length === 0) {
    await supabase.rpc('inicializar_suscripciones_profesor', { p_profesor_id: userId });
    const { data: subsRetry } = await supabase
      .from("suscripciones")
      .select("*")
      .eq("profesor_id", userId)
      .order("cantidad_dias", { ascending: true });
    subscriptions = subsRetry || [];
  }
} catch (e) {
  console.error("Error cargando datos para pagos:", e);
}
---

<ProfesorLayout title={`${pagosCopy.title} | MiGym`}>
  <div class="px-4 py-6 md:py-10 max-w-7xl mx-auto space-y-8">
    <PageHeader
      title={pagosCopy.title}
      subtitle={pagosCopy.description}
      breadcrumbs={[
        { label: "Inicio", href: "/profesor" },
        { label: "Pagos" }
      ]}
    />

    <div class="bg-transparent rounded-2xl">
      <TablaPagos client:load initialAlumnos={alumnosPagos} initialSubscriptions={subscriptions} />
    </div>
  </div>
</ProfesorLayout>
