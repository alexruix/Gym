---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { InviteStudentForm } from "@/components/organisms/profesor/alumnos/InviteStudentForm";
import { inviteStudentCopy } from "@/data/es/profesor/alumnos";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import CreationHeader from "@/components/molecules/profesor/CreationHeader.astro";
import FormContainer from "@/components/molecules/profesor/FormContainer.astro";

// SSR: Fetch planes del profesor
const supabase = createSupabaseServerClient(Astro);
const user = Astro.locals.user;
const userId = user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

const { data: plans, error } = await supabase
  .from("planes")
  .select("id, nombre, duracion_semanas, frecuencia_semanal")
  .eq("profesor_id", userId)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando planes:", error);
}

// SSR: Fetch turnos del profesor
const { data: turnos, error: turnosError } = await supabase
  .from("turnos")
  .select("id, nombre, hora_inicio, hora_fin")
  .eq("profesor_id", userId)
  .order("hora_inicio", { ascending: true });

if (turnosError) {
  console.error("Error cargando turnos:", turnosError);
}
---

<ProfesorLayout title="Invitar Alumno | MiGym">
  <div class="px-4 py-8 md:py-12 max-w-7xl mx-auto space-y-12">
    <CreationHeader 
      title={inviteStudentCopy.header.title}
      subtitle={inviteStudentCopy.header.subtitle}
      backHref="/profesor/alumnos"
      backLabel="Volver a Alumnos"
    />

    <FormContainer size="lg">
      <InviteStudentForm client:load plans={plans || []} turnos={turnos || []} />
    </FormContainer>
  </div>
</ProfesorLayout>
