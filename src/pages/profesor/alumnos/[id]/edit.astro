---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { StudentEditForm } from '@/components/organisms/profesor/alumnos/StudentEditForm.tsx';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import CreationHeader from "@/components/molecules/profesor/CreationHeader.astro";
import FormContainer from "@/components/molecules/profesor/FormContainer.astro";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth & Safety check
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect("/login");

// 2. Fetch Alumno (SSR)
const { data: alumno, error } = await supabase
  .from("alumnos")
  .select("*")
  .eq("id", id)
  .eq("profesor_id", user.id)
  .single();

if (error || !alumno) {
  return Astro.redirect("/profesor/alumnos?error=not-found");
}

const { data: turnos, error: turnosError } = await supabase
  .from("turnos")
  .select("id, nombre, hora_inicio, hora_fin")
  .eq("profesor_id", user.id)
  .order("hora_inicio", { ascending: true });

if (turnosError) {
  console.error("Error cargando turnos:", turnosError);
}

const { data: subscriptions } = await supabase
  .from("suscripciones")
  .select("id, nombre, monto, cantidad_dias")
  .eq("profesor_id", user.id)
  .order("cantidad_dias", { ascending: true });

const athleteData = {
    id: alumno.id,
    nombre: alumno.nombre,
    email: alumno.email || "",
    telefono: alumno.telefono || "",
    fecha_inicio: alumno.fecha_inicio || new Date().toISOString(),
    dia_pago: alumno.dia_pago || 1,
    monto: alumno.monto || 0,
    suscripcion_id: alumno.suscripcion_id || null,
    monto_personalizado: !!alumno.monto_personalizado,
    notas: alumno.notas || "",
    turno_id: alumno.turno_id || null,
    dias_asistencia: alumno.dias_asistencia || [],
};

const title = `Editar ${alumno.nombre} | MiGym`;
---

<ProfesorLayout title={title}>
  <div class="px-4 py-8 md:py-12 max-w-7xl mx-auto space-y-12 animate-in fade-in slide-in-from-bottom-4 duration-700">
    
    <CreationHeader 
      title="Editar Alumno"
      subtitle={`Actualizá los datos de contacto y notas médicas de ${alumno.nombre}.`}
      backHref={`/profesor/alumnos/${id}`}
      backLabel="Volver al perfil"
    />

    <FormContainer size="lg">
        <StudentEditForm 
            client:load 
            alumno={athleteData} 
            turnos={turnos || []}
            subscriptions={subscriptions || []}
        />
    </FormContainer>

  </div>
</ProfesorLayout>
