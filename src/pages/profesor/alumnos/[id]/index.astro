---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { AthleteHeader } from '@/components/organisms/profesor/perfil/AthleteHeader';
import { StudentProfileManager } from '@/components/organisms/profesor/perfil/StudentProfileManager.tsx';
import { InconsistencyAlert } from '@/components/molecules/InconsistencyAlert';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import type { AlumnoRow, PlanRow, ExerciseLibraryItem } from "@/types/dashboard.types";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth & Safety check
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

// 2. Fetch Paralelo Total: Alumno, Suscripciones, Biblioteca y Última Sesión
const [alumnoRes, subRes, libraryRes, lastSessionRes] = await Promise.all([
  supabase
    .from("alumnos")
    .select(`
      *,
      suscripciones (*),
      turnos (*),
      pagos (
        id,
        monto,
        estado,
        fecha_vencimiento,
        fecha_pago
      ),
      planes (
        id,
        nombre,
        is_template,
        duracion_semanas,
        rutinas_diarias (
          id,
          dia_numero,
          nombre_dia,
          orden,
          ejercicios_plan (
            id,
            orden,
            series,
            reps_target,
            descanso_seg,
            exercise_type,
            position,
            grupo_bloque_id,
            grupo_nombre,
            biblioteca_ejercicios (
              id,
              nombre,
              media_url
            ),
            ejercicio_plan_personalizado (
              alumno_id,
              semana_numero,
              series,
              reps_target,
              descanso_seg,
              peso_target
            )
          )
        )
      )
    `)
    .eq("id", id)
    .eq("profesor_id", user.id)
    .single(),
    
  supabase
    .from("suscripciones")
    .select("*")
    .eq("profesor_id", user.id)
    .order("cantidad_dias", { ascending: true }),

  supabase
    .from("biblioteca_ejercicios")
    .select("id, nombre, media_url, parent_id, is_template_base, tags")
    .eq("profesor_id", user.id)
    .order("nombre", { ascending: true }),

  supabase
    .from("sesiones_instanciadas")
    .select("updated_at, completed_at")
    .eq("alumno_id", id)
    .eq("estado", "completada")
    .order("completed_at", { ascending: false })
    .limit(1)
    .maybeSingle()
]);

const alumno = alumnoRes.data as unknown as AlumnoRow;
if (alumnoRes.error || !alumno) return Astro.redirect("/profesor/alumnos?error=not-found");

const allSubscriptions = (subRes.data as any[]) || [];
const exercises = (libraryRes.data as ExerciseLibraryItem[]) || [];
const ultimaSesion = lastSessionRes.data as any;

// 3. Lógica de Negocio (Inconsistencias)
const actualDays = (alumno.dias_asistencia || []).length;
const currentSub = alumno.suscripciones;
const planDays = currentSub?.cantidad_dias || 0;
const isInconsistent = !alumno.monto_personalizado && actualDays > planDays;

let targetPlan = null;
if (isInconsistent && allSubscriptions.length > 0) {
  targetPlan = allSubscriptions.find(s => s.cantidad_dias >= actualDays) || allSubscriptions[allSubscriptions.length - 1];
  if (targetPlan?.id === currentSub?.id) targetPlan = null;
}

// 3. Mapeo de datos para componentes
const sortedPagos = (alumno.pagos || []).sort((a: any, b: any) => new Date(b.fecha_vencimiento).getTime() - new Date(a.fecha_vencimiento).getTime());
const pago_activo = sortedPagos.length > 0 ? sortedPagos[0] : null;

const studentData = {
  id: alumno.id,
  nombre: alumno.nombre,
  email: alumno.email || "",
  estado: (alumno.estado as any) || 'activo',
  telefono: alumno.telefono || undefined,
  fecha_inicio: alumno.fecha_inicio,
  dia_pago: alumno.dia_pago,
  monto: alumno.monto || null,
  ultima_sesion: (ultimaSesion && ('completed_at' in ultimaSesion || 'updated_at' in ultimaSesion)) 
    ? (ultimaSesion.completed_at || ultimaSesion.updated_at) 
    : null,
  pago_activo,
  historial_pagos: sortedPagos,
  suscripcion: alumno.suscripciones,
  dias_asistencia: alumno.dias_asistencia || [],
  turno: alumno.turnos,
  peso_actual: alumno.peso_actual,
  objetivo_principal: alumno.objetivo_principal,
  lesiones: alumno.lesiones,
  fecha_nacimiento: alumno.fecha_nacimiento,
  genero: alumno.genero,
  profesion: alumno.profesion,
  nivel_experiencia: alumno.nivel_experiencia,
  perfil_completado: alumno.perfil_completado
};

const assignedPlan = (alumno.planes && Array.isArray(alumno.planes)) 
  ? (alumno.planes[0] as unknown as PlanRow) 
  : (alumno.planes as unknown as PlanRow || null);
const planName = assignedPlan?.nombre;

---

<ProfesorLayout title={`${alumno.nombre} - Ficha del Alumno | MiGym`}>
  <div class="px-4 py-4 md:py-12 md:px-10 max-w-[1600px] mx-auto space-y-4 md:space-y-8 animate-in fade-in duration-500">
    
    {/* 1. CABECERA */}
    <section class="animate-in slide-in-from-top-4 duration-500 space-y-4 md:space-y-6 -mx-4 md:mx-0">
      {targetPlan && (
        <InconsistencyAlert
          client:load
          alumnoId={alumno.id}
          actualDays={actualDays}
          planDays={planDays}
          targetPlanId={targetPlan.id}
          targetPlanName={targetPlan.nombre}
          targetPlanMonto={targetPlan.monto}
          onSolved={() => Astro.redirect(`/profesor/alumnos/${alumno.id}`)}
        />
      )}
      <AthleteHeader client:load alumno={studentData} planName={planName} />
    </section>

    {/* 3. WORKSPACE UNIFICADO (CENTRALIZADO) */}
    <div class="w-full mx-auto animate-in slide-in-from-bottom-4 duration-700 delay-150">
      <main>
        <StudentProfileManager 
          client:load
          assignedPlan={assignedPlan}
          student={studentData}
          library={exercises}
        />
      </main>
    </div>

  </div>
</ProfesorLayout>

<style is:global>
  /* Industrial Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #a1a1aa; /* Zinc 400 */
    border-radius: 20px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #71717a; /* Zinc 500 */
  }
</style>
