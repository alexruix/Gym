---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { AthleteHeader } from '@/components/organisms/profesor/perfil/AthleteHeader';
import { HealthAlert } from '@/components/molecules/profesor/perfil/HealthAlert.tsx';
import { StudentProfileManager } from '@/components/organisms/profesor/perfil/StudentProfileManager.tsx';
import { InconsistencyAlert } from '@/components/molecules/InconsistencyAlert';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth & Safety check
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect("/login");

// 2. Fetch Alumno Completo con todo el árbol de su plan (SSR)
const { data: alumno, error } = await supabase
  .from("alumnos")
  .select(`
    *,
    suscripciones (*),
    pagos (
      id,
      monto,
      estado,
      fecha_vencimiento,
      fecha_pago
    ),
    planes (
      id,
      nombre,
      is_template,
      duracion_semanas,
      rutinas_diarias (
        id,
        dia_numero,
        nombre_dia,
        orden,
        ejercicios_plan (
          id,
          orden,
          series,
          reps_target,
          descanso_seg,
          exercise_type,
          position,
          grupo_bloque_id,
          grupo_nombre,
          biblioteca_ejercicios (
            id,
            nombre,
            media_url
          ),
          ejercicio_plan_personalizado (
            alumno_id,
            semana_numero,
            series,
            reps_target,
            descanso_seg,
            peso_target
          )
        )
      )
    )
  `)
  .eq("id", id)
  .eq("profesor_id", user.id)
  .single();

if (error || !alumno) {
  return Astro.redirect("/profesor/alumnos?error=not-found");
}

// 2.3 Fetch todas las suscripciones para alertar inconsistencias
const { data: allSubscriptions } = await supabase
  .from("suscripciones")
  .select("*")
  .eq("profesor_id", user.id)
  .order("cantidad_dias", { ascending: true });

// 2.4 Calculamos inconsistencia
const actualDays = (alumno.dias_asistencia || []).length;
const currentSub = alumno.suscripciones;
const planDays = currentSub?.cantidad_dias || 0;
const isInconsistent = !alumno.monto_personalizado && actualDays > planDays;

let targetPlan = null;
if (isInconsistent && allSubscriptions) {
  // Buscamos el plan más cercano que cubra sus días (o el de mayor días)
  targetPlan = allSubscriptions.find(s => s.cantidad_dias >= actualDays) || allSubscriptions[allSubscriptions.length - 1];
  // Si encontramos el mismo plan, no hay target
  if (targetPlan?.id === currentSub?.id) targetPlan = null;
}

// 2.5 Fetch biblioteca completa para búsqueda rápida
// ... rest remains same but I'll return the full set of variables
const { data: exercises } = await supabase
  .from("biblioteca_ejercicios")
  .select("id, nombre, media_url, parent_id, is_template_base, tags")
  .eq("profesor_id", user.id)
  .order("nombre", { ascending: true });

const { data: ultimaSesion } = await supabase
  .from("sesiones_instanciadas")
  .select("updated_at, completed_at")
  .eq("alumno_id", id)
  .eq("estado", "completada")
  .order("completed_at", { ascending: false })
  .limit(1)
  .single();

// 3. Mapeo de datos para componentes
const sortedPagos = (alumno.pagos || []).sort((a: any, b: any) => new Date(b.fecha_vencimiento).getTime() - new Date(a.fecha_vencimiento).getTime());
const pago_activo = sortedPagos.length > 0 ? sortedPagos[0] : null;

const studentData = {
  id: alumno.id,
  nombre: alumno.nombre,
  email: alumno.email || "",
  estado: (alumno.estado as any) || 'activo',
  telefono: alumno.telefono || undefined,
  fecha_inicio: alumno.fecha_inicio,
  dia_pago: alumno.dia_pago,
  monto: alumno.monto || null,
  ultima_sesion: ultimaSesion?.completed_at || ultimaSesion?.updated_at || null,
  pago_activo,
  historial_pagos: sortedPagos,
  suscripcion: alumno.suscripciones,
  dias_asistencia: alumno.dias_asistencia || []
};

const assignedPlan = Array.isArray(alumno.planes) ? alumno.planes[0] : alumno.planes;
const planName = assignedPlan?.nombre;

const sidebarProps = {
  alumno: {
    id: alumno.id,
    email: alumno.email,
    telefono: alumno.telefono,
    fecha_inicio: alumno.fecha_inicio,
    dia_pago: alumno.dia_pago,
    notas: alumno.notas,
  }
};

---

<ProfesorLayout title={`${alumno.nombre} - Ficha del Alumno | MiGym`}>
  <div class="px-5 py-6 md:py-12 md:px-10 max-w-[1600px] mx-auto space-y-8 animate-in fade-in duration-500">
    
    {/* 1. CABECERA */}
    <section class="animate-in slide-in-from-top-4 duration-500 space-y-6">
      {targetPlan && (
        <InconsistencyAlert
          client:load
          alumnoId={alumno.id}
          actualDays={actualDays}
          planDays={planDays}
          targetPlanId={targetPlan.id}
          targetPlanName={targetPlan.nombre}
          targetPlanMonto={targetPlan.monto}
          onSolved={() => Astro.redirect(`/profesor/alumnos/${alumno.id}`)}
        />
      )}
      <AthleteHeader client:load alumno={studentData} planName={planName} />
    </section>

    {/* 2. NOTAS CRÍTICAS (HEALTH STICKY) */}
    {alumno.notas && (
      <HealthAlert client:load notes={alumno.notas} className="max-w-4xl" />
    )}

    {/* 3. WORKSPACE UNIFICADO (CENTRALIZADO) */}
    <div class="w-full mx-auto animate-in slide-in-from-bottom-4 duration-700 delay-150">
      <main>
        <StudentProfileManager 
          client:load
          assignedPlan={assignedPlan}
          student={studentData}
          library={exercises}
        />
      </main>
    </div>

  </div>
</ProfesorLayout>

<style is:global>
  /* Industrial Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #a1a1aa; /* Zinc 400 */
    border-radius: 20px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #71717a; /* Zinc 500 */
  }
</style>
