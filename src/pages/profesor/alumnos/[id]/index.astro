---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { AthleteHeader } from '@/components/organisms/profesor/perfil/AthleteHeader';
import { StudentProfileSidebar } from '@/components/organisms/profesor/perfil/StudentProfileSidebar.tsx';
import { StudentRoutineWorkspace } from '@/components/organisms/profesor/perfil/StudentRoutineWorkspace.tsx';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth & Safety check
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect("/login");

// 2. Fetch Alumno Completo con todo el árbol de su plan (SSR)
const { data: alumno, error } = await supabase
  .from("alumnos")
  .select(`
    *,
    planes (
      id,
      nombre,
      rutinas_diarias (
        id,
        dia_numero,
        nombre_dia,
        orden,
        ejercicios_plan (
          id,
          orden,
          series,
          reps_target,
          descanso_seg,
          biblioteca_ejercicios (
            id,
            nombre,
            media_url
          )
        )
      )
    )
  `)
  .eq("id", id)
  .eq("profesor_id", user.id)
  .single();

if (error || !alumno) {
  return Astro.redirect("/profesor/alumnos?error=not-found");
}

// 3. Mapeo de datos para componentes
const studentData = {
  id: alumno.id,
  nombre: alumno.nombre,
  email: alumno.email || "",
  estado: (alumno.estado as any) || 'activo',
  telefono: alumno.telefono || undefined
};

// En Supabase al pedir un objeto relacionado (.single no se usa en el join unless we know it's 1:1, but here planes is 1 for the alumno technically, though it returns an array/object depending on setup)
const assignedPlan = Array.isArray(alumno.planes) ? alumno.planes[0] : alumno.planes;
const planName = assignedPlan?.nombre;

---

<ProfesorLayout title={`${alumno.nombre} - Ficha del Alumno | MiGym`}>
  <div class="px-5 py-6 md:py-12 md:px-10 max-w-[1600px] mx-auto space-y-8 animate-in fade-in duration-500">
    
    {/* 1. ANCLA (CABECERA VITAL) */}
    <section class="animate-in slide-in-from-top-4 duration-500">
      <AthleteHeader client:load alumno={studentData} planName={planName} />
    </section>

    {/* 2. SOPORTE Y DETALLE (GRID DE 3 COLUMNAS) */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      {/* COLUMNA IZQUIERDA: CONTACTO & NOTAS (30%) */}
      <aside class="order-2 lg:order-1 lg:col-span-4 xl:col-span-3 animate-in slide-in-from-left-4 duration-500 delay-150">
        <StudentProfileSidebar 
          client:load 
          notasCriticas={alumno.notas} 
          alumno={{
            email: alumno.email,
            telefono: alumno.telefono,
            fecha_inicio: alumno.fecha_inicio,
            dia_pago: alumno.dia_pago,
          }}
        />
      </aside>

      {/* COLUMNA CENTRAL: RUTINA ASIGNADA (70%) */}
      <main class="order-1 lg:order-2 lg:col-span-8 xl:col-span-9 animate-in slide-in-from-right-4 duration-500 delay-300">
        <StudentRoutineWorkspace 
          client:load 
          planData={assignedPlan}
        />
      </main>

    </div>

  </div>
</ProfesorLayout>

<style is:global>
  /* Industrial Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #a1a1aa; /* Zinc 400 */
    border-radius: 20px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #71717a; /* Zinc 500 */
  }
</style>
