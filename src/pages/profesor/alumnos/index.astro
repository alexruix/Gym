---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import PageHeader from '@/components/molecules/PageHeader.astro';
import ActionLink from '@/components/atoms/ActionLink.astro';
import { RecentStudentsTable, type RecentStudent } from '@/components/organisms/profesor/dashboard/RecentStudentsTable';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";

const supabase = createSupabaseServerClient(Astro);
const { data: userAuth } = await supabase.auth.getUser();
const user = userAuth?.user;

if (!user) {
  return Astro.redirect("/login");
}

// Fetch real students data
const { data: alumnos, error } = await supabase
  .from("alumnos")
  .select(`
    id,
    nombre,
    estado,
    planes ( nombre )
  `)
  .eq("profesor_id", user.id)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando alumnos:", error);
}

// Map to the component's expected interface
const mappedStudents: RecentStudent[] = (alumnos || []).map(a => ({
  id: a.id,
  name: a.nombre,
  // Supabase returns an object or null for single relations, or an array if it's many.
  // alumnos to planes is a Many-to-One, so it returns { nombre: string } | null
  planName: Array.isArray(a.planes) ? a.planes[0]?.nombre || null : (a.planes as any)?.nombre || null,
  status: a.estado as any
}));

---

<ProfesorLayout title="Alumnos - MiGym">
  <div class="px-4 py-6 md:py-10 max-w-7xl mx-auto space-y-8">
    <PageHeader 
      title="Alumnos" 
      subtitle="Gestiona tu lista de tus alumnos, ve su estado y accede a sus perfiles."
    >
      <ActionLink href="/profesor/alumnos/import" variant="secondary" class="flex-1 md:flex-none">
        📥 Importar Excel
      </ActionLink>
      <ActionLink href="/profesor/alumnos/new" variant="primary" uppercase class="flex-1 md:flex-none">
        ➕ Nuevo
      </ActionLink>
    </PageHeader>

    <div class="bg-white dark:bg-zinc-950/50 rounded-b-3xl rounded-t-xl border border-zinc-200 dark:border-zinc-800 shadow-sm flex-1">
      <RecentStudentsTable client:load students={mappedStudents} title="Todos los Alumnos" hideAction />
    </div>
  </div>
</ProfesorLayout>
