<ProfesorLayout title="Alumnos - MiGym">
  <div class="p-6 max-w-7xl mx-auto space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold">Alumnos</h1>
      <div class="flex gap-2">
        <a href="/profesor/alumnos/import" class="bg-secondary text-secondary-foreground px-4 py-2 rounded-lg font-bold">📥 Importar Excel</a>
        <a href="/profesor/alumnos/new" class="bg-primary text-primary-foreground px-4 py-2 rounded-lg font-bold">➕ Nuevo</a>
      </div>
    </div>
  </div>
</ProfesorLayout>
