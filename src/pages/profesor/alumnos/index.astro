---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import PageHeader from '@/components/molecules/PageHeader.astro';
import ActionLink from '@/components/atoms/ActionLink.astro';
import { StudentList } from '@/components/organisms/profesor/StudentList';
import { alumnosListCopy } from '@/data/es/profesor/alumnos';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { type StatusType } from '@/components/molecules/StatusBadge';

const supabase = createSupabaseServerClient(Astro);
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

const { data: alumnos, error } = await supabase
  .from("alumnos")
  .select(`
    id,
    nombre,
    estado,
    telefono,
    email,
    notas,
    fecha_nacimiento,
    planes ( nombre )
  `)
  .eq("profesor_id", user.id)
  .is("deleted_at", null)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando alumnos:", error);
}

// Map to the component's expected interface
const _alumnos = (alumnos || []) as any[];
const mappedStudents = _alumnos.map(a => ({
  id: a.id,
  name: a.nombre,
  planName: Array.isArray(a.planes) ? a.planes[0]?.nombre || null : (a.planes as any)?.nombre || null,
  status: a.estado as StatusType,
  email: a.email,
  telefono: a.telefono || undefined,
  notas: a.notas || undefined,
  fecha_nacimiento: a.fecha_nacimiento || undefined
}));

const c = alumnosListCopy;
---

<ProfesorLayout title={`${c.header.title} - MiGym`}>
  <div class="px-4 py-4 md:py-10 max-w-7xl mx-auto space-y-8">
    <PageHeader 
      title={c.header.title} 
      subtitle={c.header.subtitle}
      breadcrumbs={[
        { label: "Inicio", href: "/profesor" },
        { label: "Alumnos" }
      ]}
    >
      <ActionLink href="/profesor/alumnos/import" variant="secondary" class="flex-1 md:flex-none">
        {c.header.actions.import}
      </ActionLink>
      <ActionLink href="/profesor/alumnos/new" variant="industrial" uppercase class="flex-1 md:flex-none">
        {c.header.actions.new}
      </ActionLink>
    </PageHeader>

    <StudentList client:visible students={mappedStudents} />
  </div>
</ProfesorLayout>
