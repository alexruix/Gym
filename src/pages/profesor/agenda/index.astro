---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import { agendaCopy } from "@/data/es/profesor/agenda";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { AgendaConsole } from "@/components/organisms/profesor/agenda/AgendaConsole";

// El middleware ya validó la sesión y la inyectó en locals — sin round-trip extra.
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const supabase = createSupabaseServerClient(Astro);
const today = new Date().toISOString().split('T')[0];

// Fetch Paralelo Total: Turnos, Alumnos y Sesiones de hoy en un solo round-trip
const [turnosData, rawStudentsData, rawSessionsData] = await Promise.all([
  supabase
    .from("turnos")
    .select("*, dias_asistencia")
    .eq("profesor_id", user.id)
    .order("hora_inicio"),
  supabase
    .from("alumnos")
    .select("id, nombre, turno_id, dias_asistencia")
    .eq("profesor_id", user.id)
    .is("deleted_at", null),
  // Las sesiones de hoy se obtienen junto con lo demás — sin esperar los IDs de alumnos.
  // El filtro por profesor_id via JOIN garantiza seguridad RLS.
  supabase
    .from("sesiones_instanciadas")
    .select(`
      id,
      alumno_id,
      alumnos!inner(profesor_id),
      sesion_ejercicios_instanciados (
        id,
        completado,
        exercise_type,
        peso_target,
        peso_real,
        biblioteca_ejercicios ( nombre )
      )
    `)
    .eq("fecha_real", today)
    .eq("alumnos.profesor_id", user.id)
]);

const turnos = turnosData.data;
const rawStudents = rawStudentsData.data;

// Mapeo a BaseEntity (name <-> nombre) para que DashboardConsole funcione SSOT
const students = ((rawStudents || []) as any[]).map(s => ({
  ...s,
  name: s.nombre
}));

const rawSessions = rawSessionsData.data || [];

// Mapear sesiones a formato simplificado para el componente
const initialSessions = (rawSessions as any[]).map(s => {
  const exercises = s.sesion_ejercicios_instanciados || [];
  const total = exercises.length;
  const completed = exercises.filter((e: any) => e.completado).length;
  
  // Ejercicio "Core" para la telemetría (base type o primero de la lista)
  const core = exercises.find((e: any) => e.exercise_type === 'base') || exercises[0];

  return {
    alumno_id: s.alumno_id,
    progress: total > 0 ? (completed / total) * 100 : 0,
    coreExercise: core ? {
      nombre: (core as any).biblioteca_ejercicios?.nombre || "Sin ejercicio",
      peso_target: (core as any).peso_target?.toString(),
      peso_real: (core as any).peso_real?.toString()
    } : undefined
  };
});

// Conteo de alumnos con actividad hoy para el Badge
const presentCount = initialSessions.filter(s => s.progress > 0).length;

const c = agendaCopy.header;
---

<ProfesorLayout title={`${c.title} - MiGym`}>
  <main class="min-h-screen bg-white">
    <div class="p-6 max-w-7xl mx-auto space-y-8 pb-32 md:pb-6">
        <PageHeader
        title={c.title}
        subtitle={c.subtitle}
        breadcrumbs={[{ label: "Dashboard", href: "/profesor" }, { label: "Agenda" }]}
        />

        <AgendaConsole 
        client:load 
        turnos={turnos || []} 
        students={students as any} 
        initialSessions={initialSessions}
        presentCount={presentCount}
        />
    </div>
  </main>
</ProfesorLayout>
