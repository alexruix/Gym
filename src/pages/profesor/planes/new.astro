---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import { PlanForm } from '../../../components/organisms/PlanForm';
---

<ProfesorLayout title="Nuevo Plan">
  <div class="max-w-4xl mx-auto">
    <header class="mb-12 p-4 text-center md:text-left">
      <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter italic text-zinc-950 leading-none">
        Crear Nuevo <span class="text-lime-500">Plan</span>
      </h2>
      <p class="mt-4 text-zinc-500 font-bold text-lg max-w-2xl">
        Diseñá la rutina perfecta para tus alumnos. Luego podrás asignarla de forma masiva o individual.
      </p>
    </header>

    <div class="bg-white rounded-[2.5rem] border border-zinc-100 shadow-xl shadow-zinc-100/50 p-6 md:px-12 md:py-16">
      <PlanForm client:load />
    </div>
  </div>
</ProfesorLayout>
