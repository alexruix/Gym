---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { PlanForm } from "@/components/organisms/profesor/planes/PlanForm.tsx";
import { planesCopy } from "@/data/es/profesor/planes";

import { actions } from "astro:actions";

const user = Astro.locals.user;
const userId = user?.id;

if (!userId) {
  return Astro.redirect("/login");
}

// Fetch exercise library unificada (Personales + MiGym)
const { data: exercises, error } = await Astro.callAction(actions.profesor.getExerciseLibrary, {});

if (error) {
  console.error("Error cargando ejercicios:", error);
}
---

<ProfesorLayout title={`${planesCopy.header.title} | MiGym`}>
  <div class="animate-in fade-in duration-700">
    <PlanForm client:load library={exercises || []} />
  </div>
</ProfesorLayout>
