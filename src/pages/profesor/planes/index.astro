---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import PageHeader from '@/components/molecules/PageHeader.astro';
import { actions } from "astro:actions";
import { PlanesDashboard } from '@/components/organisms/profesor/planes/PlanesDashboard';
import { type PlanRowData } from '@/components/organisms/profesor/planes/PlanesTable';
import { planesCopy } from "@/data/es/profesor/planes";

// El middleware ya validó la sesión y la inyectó en locals — sin round-trip extra.
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const mappedPlanes: PlanRowData[] = [];

const c = planesCopy.list.header;
---

<ProfesorLayout title="Planificaciones - MiGym">
  <div class="px-5 py-6 md:py-12 md:px-10 max-w-7xl mx-auto space-y-8 animate-in fade-in duration-500">
    <PageHeader 
      title={c.title} 
      subtitle={c.subtitle}
    />

    <div class="animate-in slide-in-from-bottom-4 duration-500 delay-150">
      <PlanesDashboard client:load planes={mappedPlanes} />
    </div>
  </div>

  <script>
    import { toast } from "sonner";
    
    // Capturar errores de redirección (ej: Plan no encontrado tras fallo de query)
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');
    
    if (error === 'not-found') {
      toast.error("No se pudo cargar el plan. Es probable que falten columnas técnicas en la base de datos o el plan no exista.", {
        duration: 5000,
      });
      // Limpiar URL para no repetir el toast
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  </script>
</ProfesorLayout>
