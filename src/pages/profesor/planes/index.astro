---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import PageHeader from '@/components/molecules/PageHeader.astro';
import ActionLink from '@/components/atoms/ActionLink.astro';
import { PlanesDashboard } from '@/components/organisms/profesor/planes/PlanesDashboard';
import { type PlanRowData } from '@/components/organisms/profesor/planes/PlanesTable';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { planesCopy } from "@/data/es/profesor/planes";

const supabase = createSupabaseServerClient(Astro);
const { data: userAuth } = await supabase.auth.getUser();
const user = userAuth?.user;

if (!user) {
  return Astro.redirect("/login");
}

// Fetch planes data with count of current active (non-soft-deleted) students
const { data: planesData, error } = await supabase
  .from("planes")
  .select(`
    id,
    nombre,
    duracion_semanas,
    frecuencia_semanal,
    created_at,
    alumnos(id)
  `)
  .eq("profesor_id", user.id)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando planes:", error);
}

// Map to component format
const mappedPlanes: PlanRowData[] = (planesData || []).map(p => ({
  id: p.id,
  name: p.nombre,
  duration: p.duracion_semanas || 4,
  frequency: p.frecuencia_semanal || 3,
  studentsCount: Array.isArray(p.alumnos) ? p.alumnos.length : 0,
  createdAt: p.created_at,
}));

const c = planesCopy.list.header;
---

<ProfesorLayout title="Planificaciones - MiGym">
  <div class="px-5 py-6 md:py-12 md:px-10 max-w-7xl mx-auto space-y-8 animate-in fade-in duration-500">
    <PageHeader 
      title={c.title} 
      subtitle={c.subtitle}
    />

    <div class="animate-in slide-in-from-bottom-4 duration-500 delay-150">
      <PlanesDashboard client:load planes={mappedPlanes} />
    </div>
  </div>
</ProfesorLayout>
