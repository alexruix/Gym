---
import ProfesorLayout from '../../../layouts/ProfesorLayout.astro';
import { PlanesTable, type PlanRowData } from '@/components/organisms/profesor/planes/PlanesTable.tsx';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { planesCopy } from "@/data/es/profesor/planes";

const supabase = createSupabaseServerClient(Astro);
const { data: userAuth } = await supabase.auth.getUser();
const user = userAuth?.user;

if (!user) {
  return Astro.redirect("/login");
}

// Fetch planes data with count of current active (non-soft-deleted) students
const { data: planesData, error } = await supabase
  .from("planes")
  .select(`
    id,
    nombre,
    duracion_semanas,
    frecuencia_semanal,
    created_at,
    alumnos(id)
  `)
  .eq("profesor_id", user.id)
  .order("created_at", { ascending: false });

if (error) {
  console.error("Error cargando planes:", error);
}

// Map to component format
const mappedPlanes: PlanRowData[] = (planesData || []).map(p => ({
  id: p.id,
  name: p.nombre,
  duration: p.duracion_semanas || 4,
  frequency: p.frecuencia_semanal || 3,
  studentsCount: Array.isArray(p.alumnos) ? p.alumnos.length : 0,
  createdAt: p.created_at,
}));

const c = planesCopy.list.header;
---

<ProfesorLayout title="Planes - MiGym">
  <div class="px-5 py-6 md:py-12 md:px-10 max-w-7xl mx-auto space-y-8 animate-in fade-in duration-500">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="space-y-1">
        <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 uppercase">
          {c.title}
        </h1>
        <p class="text-base text-zinc-500 dark:text-zinc-400">
          {c.subtitle}
        </p>
      </div>
      <div class="flex w-full md:w-auto mt-2 md:mt-0">
        <a href="/profesor/planes/new" class="w-full md:w-auto text-center bg-lime-400 text-zinc-950 px-6 py-3 rounded-2xl font-black hover:bg-lime-500 transition-colors shadow-sm text-[11px] uppercase tracking-widest active:scale-95">
          {c.newBtn}
        </a>
      </div>
    </header>

    <div class="animate-in slide-in-from-bottom-4 duration-500 delay-150">
      <PlanesTable client:load planes={mappedPlanes} />
    </div>
  </div>
</ProfesorLayout>
