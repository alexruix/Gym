---
import ProfesorLayout from "@/layouts/ProfesorLayout.astro";
import { ImportPlansModal } from "@/components/organisms/profesor/planes/ImportPlansModal";
import { planesCopy } from "@/data/es/profesor/planes";
import { MoveLeft, FileSpreadsheet } from "lucide-react";

---

<ProfesorLayout title={`Importar Planes | MiGym`}>
  <div class="px-4 py-6 md:py-10 max-w-4xl mx-auto space-y-8 animate-in fade-in duration-500">
    <a 
      href="/profesor/planes" 
      class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-zinc-500 hover:text-lime-500 transition-colors group"
    >
      <MoveLeft className="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
      Volver a planes
    </a>

    <header class="space-y-1">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 flex items-center gap-3">
        <div class="p-2 bg-lime-400/10 rounded-xl">
            <FileSpreadsheet className="w-8 h-8 text-lime-500" />
        </div>
        {planesCopy.list.import.title}
      </h1>
      <p class="text-base text-zinc-500 dark:text-zinc-400 font-medium">
        {planesCopy.list.import.description}
      </p>
    </header>

    <div class="bg-white dark:bg-zinc-950/50 p-6 sm:p-10 rounded-3xl border border-zinc-200 dark:border-zinc-800 shadow-sm min-h-[400px] flex items-center justify-center relative overflow-hidden">
        <!-- Subtle Background Pattern -->
        <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] pointer-events-none">
            <div class="absolute inset-x-0 -top-40 -bottom-40 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-lime-500 via-transparent to-transparent"></div>
        </div>
        
        <div class="relative z-10 w-full max-w-2xl">
            <ImportPlansModal 
              client:load 
              isOpen={true} 
              onOpenChange={(open) => {
                if (!open) window.location.href = "/profesor/planes";
              }} 
              onSuccess={() => {
                window.location.href = "/profesor/planes";
              }} 
            />
        </div>
    </div>
  </div>
</ProfesorLayout>
