---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { PlanForm } from '@/components/organisms/profesor/planes/PlanForm.tsx';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import CreationHeader from "@/components/molecules/profesor/CreationHeader.astro";
import FormContainer from "@/components/molecules/profesor/FormContainer.astro";
import type { PlanRow } from "@/types/dashboard.types";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth check
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

import { actions } from "astro:actions";

// 2. Fetch Paralelo: Plan completo y Biblioteca
const [planRes, libraryRes] = await Promise.all([
  supabase
    .from("planes")
    .select(`
      id,
      nombre,
      duracion_semanas,
      frecuencia_semanal,
      is_template,
      rutinas_diarias (
        id,
        dia_numero,
        nombre_dia,
        orden,
        ejercicios_plan (
          ejercicio_id,
          series,
          reps_target,
          descanso_seg,
          orden,
          exercise_type,
          position,
          peso_target,
          notas,
          grupo_bloque_id,
          grupo_nombre,
          grupo_tipo_bloque,
          grupo_vueltas,
          grupo_descanso_ronda,
          grupo_descanso_final
        )
      ),
      plan_rotaciones (
        position,
        applies_to_days,
        cycles
      )
    `)
    .eq("id", id)
    .eq("profesor_id", user.id)
    .single(),
  Astro.callAction(actions.profesor.getExerciseLibrary, {})
]);

const planData = (planRes.data as unknown) as PlanRow;
if (planRes.error || !planData) {
  return Astro.redirect("/profesor/planes?error=not-found");
}
const exercises = libraryRes.data || [];

// 4. Map DB data to Form Schema and Ensure 365 days with sanitization
const rutinasMap = new Map(planData.rutinas_diarias.map((r: any) => [r.dia_numero, r]));

const initialValues = {
    id: planData.id,
    nombre: planData.nombre,
    duracion_semanas: planData.duracion_semanas,
    frecuencia_semanal: planData.frecuencia_semanal,
    is_template: planData.is_template ?? true,
    rutinas: Array.from({ length: 365 }, (_, i) => {
        const diaNum = i + 1;
        const existing = rutinasMap.get(diaNum) as any;
        
        return {
            dia_numero: diaNum,
            nombre_dia: existing?.nombre_dia || `Rutina ${diaNum}`,
            ejercicios: (existing?.ejercicios_plan || [])
                .sort((a: any, b: any) => a.orden - b.orden)
                .map((ej: any) => ({
                    ejercicio_id: ej.ejercicio_id,
                    series: ej.series ?? 3,
                    reps_target: ej.reps_target ?? "10",
                    descanso_seg: ej.descanso_seg ?? 60,
                    orden: ej.orden ?? 0,
                    exercise_type: ej.exercise_type ?? "base",
                    position: ej.position ?? 0,
                    peso_target: ej.peso_target ?? "",
                    notas: ej.notas ?? "",
                    grupo_bloque_id: ej.grupo_bloque_id || undefined,
                    grupo_nombre: ej.grupo_nombre || undefined,
                    grupo_tipo_bloque: ej.grupo_tipo_bloque || 'agrupador',
                    grupo_vueltas: ej.grupo_vueltas || 1,
                    grupo_descanso_ronda: ej.grupo_descanso_ronda || 0,
                    grupo_descanso_final: ej.grupo_descanso_final || 0
                }))
        };
    }),
    rotaciones: planData.plan_rotaciones || []
};

// Ensure we have 7 days in the form even if some are empty (to match defaultValues logic if needed)
// Actually, PlanForm handles empty days if we provide fewer, but the Tabs might look better if we provide all 7.
// For now, let's stick to the active ones + padding if necessary.
// PlanForm creates 7 days by default if rutinas is missing. If we provide it, it uses it.

const title = `Editar ${planData.nombre} | MiGym`;
---

<ProfesorLayout title={title}>
  <div class="px-4 py-8 md:py-12 max-w-7xl mx-auto space-y-12">
    <CreationHeader 
      title="Editar plan"
      subtitle={`Modificá la estructura, rutinas y rotaciones de ${planData.nombre}.`}
      backHref={`/profesor/planes/${id}`}
      backLabel="Volver al detalle"
    />

    <FormContainer size="lg">
      <PlanForm 
        client:load 
        library={exercises || []} 
        initialValues={initialValues}
        onSuccess={() => Astro.redirect(`/profesor/planes/${id}`)}
        onCancel={() => Astro.redirect(`/profesor/planes/${id}`)}
      />
    </FormContainer>
  </div>
</ProfesorLayout>
