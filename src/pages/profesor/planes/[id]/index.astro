---
import ProfesorLayout from '../../../../layouts/ProfesorLayout.astro';
import { PlanDetail } from '@/components/organisms/profesor/planes/PlanDetail.tsx';
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { planesCopy } from "@/data/es/profesor/planes";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);

// 1. Auth check
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect("/login");

// 2. Fetch plan completo con rutinas, ejercicios y alumnos activos
const query = supabase
  .from("planes")
  .select(`
    id,
    nombre,
    duracion_semanas,
    frecuencia_semanal,
    created_at,
    rutinas_diarias (
      id,
      dia_numero,
      nombre_dia,
      orden,
      ejercicios_plan (
        id,
        orden,
        biblioteca_ejercicios (
          id,
          nombre,
          media_url
        )
      )
    ),
    alumnos (
      id,
      nombre,
      email,
      estado,
      telefono,
      notas
    )
  `)
  .eq("id", id)
  .eq("profesor_id", user.id)
  .single();

const { data, error } = await query;
const plan = data as any;

if (error || !plan) {
  return Astro.redirect("/profesor/planes?error=not-found");
}

// 3. Ordenar rutinas y ejercicios por orden
const sortedRutinas = (plan.rutinas_diarias || [])
  .sort((a: any, b: any) => a.dia_numero - b.dia_numero)
  .map((r: any) => ({
    ...r,
    ejercicios_plan: (r.ejercicios_plan || []).sort((a: any, b: any) => a.orden - b.orden),
  }));

const c = planesCopy.detail;

// 4. Fetch biblioteca completa para el buscador unificado
const { data: exercises } = await supabase
  .from("biblioteca_ejercicios")
  .select("id, nombre, media_url, parent_id, is_template_base, tags")
  .eq("profesor_id", user.id)
  .order("nombre", { ascending: true });
---

<ProfesorLayout title={`${plan.nombre} | MiGym`}>
  <div class="px-4 py-4 md:py-12 md:px-10 max-w-6xl mx-auto space-y-4 md:space-y-8 animate-in fade-in duration-500">

    {/* CABECERA VITAL */}
    <section class="animate-in slide-in-from-top-4 duration-500 space-y-4 md:space-y-6">
      <PlanDetail client:load library={exercises || []} plan={{
        id: plan.id,
        nombre: plan.nombre,
        duracion_semanas: plan.duracion_semanas,
        frecuencia_semanal: plan.frecuencia_semanal,
        created_at: plan.created_at,
        rutinas: sortedRutinas as any,
        alumnos: (plan.alumnos || []) as any,
      }} />
    </section>

  </div>
</ProfesorLayout>
