---
import ProfesorLayout from "../../layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import ActionLink from "@/components/atoms/ActionLink.astro";
import { dashboardCopy } from "@/data/es/profesor/dashboard";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { Plus } from "lucide-react";

// Organismos
import { DashboardMetrics } from "@/components/organisms/profesor/dashboard/DashboardMetrics";
import {
  AlertCenter,
  type AlertData,
} from "@/components/organisms/profesor/dashboard/AlertCenter";
import {
  ActivityFeed,
  type ActivityLog,
} from "@/components/organisms/profesor/dashboard/ActivityFeed";
import {
  StudentList,
  type Student,
} from "@/components/organisms/profesor/StudentList";
import { QuickActionFab } from "@/components/organisms/profesor/dashboard/QuickActionFab";
import { DashboardOnboarding } from "@/components/organisms/profesor/dashboard/DashboardOnboarding";

// ─── Autenticación ────────────────────────────────────────────────────────────
const supabase = createSupabaseServerClient(Astro);
const { data: userAuth } = await supabase.auth.getUser();
const user = userAuth?.user;
if (!user) return Astro.redirect("/login");

// ─── Nombre del profesor (para el saludo personalizado) ───────────────────────
const { data: profesor } = await supabase
  .from("profesores")
  .select("nombre")
  .eq("id", user.id)
  .maybeSingle();
const profesorNombre = profesor?.nombre?.split(" ")[0] ?? "profe";

// ─── 1. Alumnos (query extendido con todos los campos necesarios) ──────────────
const { data: allStudents, error: studentsError } = await supabase
  .from("alumnos")
  .select(
    `
    id,
    nombre,
    estado,
    email,
    telefono,
    dia_pago,
    monto,
    planes ( id, nombre )
  `
  )
  .eq("profesor_id", user.id)
  .is("deleted_at", null)
  .order("created_at", { ascending: false });

if (studentsError) {
  console.error("[Dashboard] Error cargando alumnos:", studentsError);
}

const students = allStudents || [];
const studentIds = students.map((s) => s.id);

// ─── 1.5 Fetch Últimas Sesiones (para riesgo y adherencia) ─────────────────────
const { data: allLastSessions } = studentIds.length > 0
  ? await supabase
      .from("sesiones_instanciadas")
      .select("alumno_id, completed_at, updated_at")
      .in("alumno_id", studentIds)
      .eq("estado", "completada")
      .order("completed_at", { ascending: false })
  : { data: [] };

const studentLastSessionMap = new Map<string, string>();
(allLastSessions || []).forEach(s => {
  if (!studentLastSessionMap.has(s.alumno_id)) {
    studentLastSessionMap.set(s.alumno_id, s.completed_at || s.updated_at);
  }
});
const totalStudents = students.length;
const activeStudents = students.filter((s) => s.estado === "activo");
const activeStudentsCount = activeStudents.length;

// ─── 2. Onboarding ────────────────────────────────────────────────────────────
const { count: planesCount } = await supabase
  .from("planes")
  .select("id", { count: "exact", head: true })
  .eq("profesor_id", user.id);

const hasPlans = (planesCount || 0) > 0;
const hasStudents = totalStudents > 0;

// ─── 3. Métricas reales ───────────────────────────────────────────────────────

// Alumnos sin plan asignado
const noPlanStudents: AlertData[] = students
  .filter((s) => s.planes === null)
  .map((s) => ({ id: s.id, studentName: s.nombre }));

// Alumnos en riesgo de abandono: activos con última sesión > 7 días (o sin sesión)
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

const atRiskStudents: AlertData[] = activeStudents
  .filter((s) => {
    const lastSession = studentLastSessionMap.get(s.id);
    if (!lastSession) return true; // Nunca entrenó
    return new Date(lastSession) < sevenDaysAgo;
  })
  .filter((s) => s.planes !== null) // Solo los que SÍ tienen plan (esperaban entrenar)
  .map((s) => {
    const lastSession = studentLastSessionMap.get(s.id);
    const daysInactive = lastSession
      ? Math.floor(
          (Date.now() - new Date(lastSession).getTime()) /
            (1000 * 60 * 60 * 24)
        )
      : undefined;
    return {
      id: s.id,
      studentName: s.nombre,
      phone: s.telefono ?? undefined,
      daysInactive,
    };
  });

// Adherencia real: % de activos que entrenaron en los últimos 7 días
const trainedRecently = activeStudents.filter((s) => {
  const lastSession = studentLastSessionMap.get(s.id);
  return lastSession && new Date(lastSession) >= sevenDaysAgo;
});
const adherenceRate =
  activeStudentsCount > 0
    ? Math.round((trainedRecently.length / activeStudentsCount) * 100)
    : 0;

// ─── 4. Pagos (query a tabla real) ───────────────────────────────────────────
const { data: pagosData } = studentIds.length > 0
  ? await supabase
      .from("pagos")
      .select("alumno_id, monto, fecha_vencimiento, fecha_pago, estado")
      .in("alumno_id", studentIds)
  : { data: [] };

const pagos = pagosData || [];

// Cuotas vencidas / pendientes
const expiringPayments: AlertData[] = pagos
  .filter((p) => p.estado === "pendiente" || p.estado === "vencido")
  .flatMap((p) => {
    const student = students.find((s) => s.id === p.alumno_id);
    if (!student) return [];
    const daysLate = p.fecha_vencimiento
      ? Math.max(
          0,
          Math.floor(
            (Date.now() - new Date(p.fecha_vencimiento).getTime()) /
              (1000 * 60 * 60 * 24)
          )
        )
      : 0;
    return [
      {
        id: student.id,
        studentName: student.nombre,
        phone: student.telefono ?? undefined,
        daysLate,
      },
    ];
  });

// Cobros del mes actual
const startOfMonth = new Date();
startOfMonth.setDate(1);
startOfMonth.setHours(0, 0, 0, 0);

const monthlyRevenue = pagos
  .filter(
    (p) =>
      p.estado === "pagado" &&
      p.fecha_pago &&
      new Date(p.fecha_pago) >= startOfMonth
  )
  .reduce((sum, p) => sum + (p.monto || 0), 0);

// ─── 5. Alertas combinadas ────────────────────────────────────────────────────
const hasAlerts =
  expiringPayments.length > 0 ||
  atRiskStudents.length > 0 ||
  noPlanStudents.length > 0;

// ─── 6. Top 5 alumnos para tabla ─────────────────────────────────────────────
const recentStudents: Student[] = students.slice(0, 5).map((s) => ({
  id: s.id,
  name: s.nombre,
  email: s.email,
  planName: Array.isArray(s.planes)
    ? s.planes[0]?.nombre || null
    : (s.planes as any)?.nombre || null,
  status: s.estado as any,
}));

// ─── 7. Activity Feed — Sesiones reales ──────────────────────────────────────
const { data: recentSessions } = studentIds.length > 0
  ? await supabase
      .from("sesiones_instanciadas")
      .select("id, fecha_real, alumno_id, alumnos ( nombre )")
      .in("alumno_id", studentIds)
      .order("fecha_real", { ascending: false })
      .limit(10)
  : { data: [] };

const now = new Date();
const activities: ActivityLog[] = (recentSessions || []).map((s: any) => {
  const sessionDate = new Date(s.fecha_real);
  const diffDays = Math.floor(
    (now.getTime() - sessionDate.getTime()) / (1000 * 60 * 60 * 24)
  );
  const timeAgo =
    diffDays === 0
      ? "Hoy"
      : diffDays === 1
        ? "Ayer"
        : `Hace ${diffDays} días`;
  return {
    id: s.id,
    type: "session_completed" as const,
    studentName: s.alumnos?.nombre ?? "Alumno",
    timeAgo,
  };
});

const c = dashboardCopy.header;
---

<ProfesorLayout title={`${c.title} - MiGym`}>
  <div class="p-6 max-w-7xl mx-auto space-y-8 pb-32 md:pb-6">

    <!-- Header personalizado -->
    <PageHeader
      title={`Hola, ${profesorNombre}`}
      subtitle="Tu panel de control. Todo lo que necesitás de un vistazo."
      hideActionsOnMobile={true}
      breadcrumbs={[{ label: "Inicio" }]}
    >
      <ActionLink href="/profesor/alumnos/new" variant="secondary">
        {c.actions.newStudent}
      </ActionLink>
      <ActionLink href="/profesor/planes/new" variant="primary" uppercase>
        <Plus className="w-4 h-4" client:load />
        {c.actions.createPlan}
      </ActionLink>
    </PageHeader>

    <!-- Onboarding (solo si aplica) -->
    <DashboardOnboarding
      client:load
      hasPlans={hasPlans}
      hasStudents={hasStudents}
    />

    <!-- Métricas — 4 cards en grid -->
    <DashboardMetrics
      activeStudents={activeStudentsCount}
      pendingRoutines={noPlanStudents.length}
      adherenceRate={adherenceRate}
      monthlyRevenue={monthlyRevenue}
    />

    <!-- AlertCenter — PRIMERO (urgencia > no urgente) -->
    {hasAlerts && (
      <AlertCenter
        client:load
        expiringPayments={expiringPayments}
        atRiskStudents={atRiskStudents}
        noPlanStudents={noPlanStudents}
      />
    )}

    <!-- Lista de alumnos recientes -->
    <StudentList client:load students={recentStudents} isDashboard={true} />

    <!-- Activity Feed -->
    <ActivityFeed activities={activities} />

  </div>

  <QuickActionFab client:load />
</ProfesorLayout>
