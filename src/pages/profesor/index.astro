---
import ProfesorLayout from "../../layouts/ProfesorLayout.astro";
import PageHeader from "@/components/molecules/PageHeader.astro";
import ActionLink from "@/components/atoms/ActionLink.astro";
import { dashboardCopy } from "@/data/es/profesor/dashboard";
import { createSupabaseServerClient } from "@/lib/supabase-ssr";
import { Plus } from "lucide-react";

// Organismos
import { DashboardConsole } from "@/components/organisms/profesor/dashboard/DashboardConsole";
import { DashboardOnboarding } from "@/components/organisms/profesor/dashboard/DashboardOnboarding";
import { QuickActionFab } from "@/components/organisms/profesor/dashboard/QuickActionFab";
import { DashboardCard } from "@/components/molecules/DashboardCard";
import { AlertCircle, ChevronRight } from "lucide-react";
import { actions } from "astro:actions";

// ─── Autenticación y Saludo ──────────────────────────────────────────────────
const supabase = createSupabaseServerClient(Astro);
const { data: userAuth } = await supabase.auth.getUser();
const user = userAuth?.user;
if (!user) return Astro.redirect("/login");

// ─── Hidratación Híbrida: Fetch Paralelo ──────────────────────────────────────
const [profesorData, initialData, planesCountData] = await Promise.all([
  supabase.from("profesores").select("nombre").eq("id", user.id).maybeSingle(),
  Astro.callAction(actions.profesor.getDashboardData, {}),
  supabase.from("planes").select("id", { count: "exact", head: true }).eq("profesor_id", user.id)
]);

if (initialData.error) {
  console.error("[Dashboard] Error inicial:", initialData.error);
}

const profesorNombre = (profesorData.data as any)?.nombre?.split(" ")[0] ?? "profe";
const data = initialData.data!;
const hasPlans = (planesCountData.count || 0) > 0;
const hasStudents = data.stats.activeStudents > 0;

const c = dashboardCopy.header;
---

<ProfesorLayout title={`${c.title} - MiGym`}>
  <div class="px-4 py-4 md:py-12 md:px-10 max-w-7xl mx-auto space-y-4 md:space-y-8 pb-32 md:pb-6">

    <!-- Header personalizado -->
    <PageHeader
      title={`Hola, ${profesorNombre}`}
      subtitle="Tu panel de control."
      hideActionsOnMobile={true}
    >
      <ActionLink href="/profesor/alumnos/new" variant="secondary">
        {c.actions.newStudent}
      </ActionLink>
      <ActionLink href="/profesor/planes/new" variant="primary" uppercase>
        <Plus className="w-4 h-4" client:load />
        {c.actions.createPlan}
      </ActionLink>
    </PageHeader>

    <!-- Onboarding (solo si aplica) -->
    <DashboardOnboarding
      client:only="react"
      hasPlans={hasPlans}
      hasStudents={hasStudents}
    />

    <!-- Vigía: Alertas Operativas -->
    {data.noPlanStudents?.length > 0 && (
      <DashboardCard className="border border-red-500/20 bg-red-500/5 backdrop-blur-md">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center shrink-0">
              <AlertCircle className="w-5 h-5 text-red-500" />
            </div>
            <div>
              <h3 class="font-bold text-red-500 text-sm md:text-lg">¡Atención! {data.noPlanStudents.length} {data.noPlanStudents.length === 1 ? 'Alumno sin plan' : 'Alumnos sin plan'}</h3>
              <p class="text-zinc-400 text-xs md:text-sm font-medium">Están listos para entrenar. Asignales una rutina cuanto antes.</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            {data.noPlanStudents.slice(0, 3).map((s: any) => (
              <a href={`/profesor/alumnos/${s.id}`} class="text-[10px] font-bold uppercase tracking-widest bg-white/5 hover:bg-white/10 px-3 py-1.5 rounded-full text-zinc-300 transition-colors flex items-center gap-1 border border-white/5">
                {s.studentName.split(' ')[0]} <ChevronRight className="w-3 h-3" />
              </a>
            ))}
            {data.noPlanStudents.length > 3 && (
              <span class="text-[10px] font-bold uppercase tracking-widest bg-white/5 px-3 py-1.5 rounded-full text-zinc-500">
                +{data.noPlanStudents.length - 3} más
              </span>
            )}
          </div>
        </div>
      </DashboardCard>
    )}

    <!-- Dashboard Console (Reactive Orchestrator) -->
    <DashboardConsole 
      client:load 
      initialData={data} 
    />

  </div>

  <QuickActionFab client:load />  
</ProfesorLayout>
