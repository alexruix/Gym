---
import ProfesorLayout from '../../layouts/ProfesorLayout.astro';
---

<ProfesorLayout title="Dashboard Profesor - MiGym">
  <div class="p-6 max-w-7xl mx-auto space-y-8">
    <header class="flex justify-between items-center">
      <h1 class="text-3xl font-bold">Dashboard</h1>
      <div class="flex gap-2">
        <a href="/profesor/alumnos/new" class="bg-primary text-primary-foreground px-4 py-2 rounded-lg font-bold">Nuevo Alumno</a>
        <a href="/profesor/planes/new" class="bg-secondary text-secondary-foreground px-4 py-2 rounded-lg font-bold">Crear Plan</a>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {/* Tarjetas de Resumen */}
      <div class="bg-card p-6 rounded-xl border shadow-sm">
        <p class="text-sm font-medium text-muted-foreground uppercase tracking-widest">Alumnos Activos</p>
        <p class="text-3xl font-bold mt-1">45</p>
      </div>
      <div class="bg-card p-6 rounded-xl border shadow-sm">
        <p class="text-sm font-medium text-muted-foreground uppercase tracking-widest">Planes</p>
        <p class="text-3xl font-bold mt-1">8</p>
      </div>
      <div class="bg-card p-6 rounded-xl border shadow-sm">
        <p class="text-sm font-medium text-muted-foreground uppercase tracking-widest">Vencen Hoy</p>
        <p class="text-3xl font-bold mt-1 text-yellow-600">12</p>
      </div>
      <div class="bg-card p-6 rounded-xl border shadow-sm">
        <p class="text-sm font-medium text-muted-foreground uppercase tracking-widest">Morosos</p>
        <p class="text-3xl font-bold mt-1 text-destructive">3</p>
      </div>
    </div>
  </div>
</ProfesorLayout>
