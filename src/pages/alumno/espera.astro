---
import Layout from '../../layouts/Layout.astro';
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { LogOut, Dumbbell, Clock } from 'lucide-react';

const supabase = getAuthenticatedClient(Astro);
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { data: alumno } = await supabase
  .from('alumnos')
  .select('nombre, plan_id')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();



// Si mágicamente ya le asignaron el plan mientras miraba esto, mandarlo al home
if (alumno?.plan_id) {
  return Astro.redirect('/alumno');
}
---

<Layout title="Preparando motores... - MiGym">
  <div class="min-h-screen bg-black text-white px-6 py-10 flex flex-col relative font-sans overflow-hidden">
    
    <!-- Ambient glows -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-lime-500/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 -right-32 w-[600px] h-[600px] bg-fuchsia-500/10 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="flex justify-between items-center mb-12 relative z-10 w-full max-w-lg mx-auto">
      <div class="flex flex-col">
        <h1 class="industrial-title-xl">
          HOLA, <span class="text-lime-500">{alumno?.nombre?.split(' ')[0] || 'Alumno'}</span>
        </h1>
      </div>
      
      <form action="/api/auth/signout" method="POST">
        <button type="submit" class="industrial-button-muted">
          <LogOut className="w-5 h-5" />
        </button>
      </form>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center w-full max-w-lg mx-auto relative z-10">
      
      <div class="industrial-card w-24 h-24 bg-zinc-900 border-zinc-800 flex items-center justify-center p-0 mb-8 relative animate-pulse group">
        <div class="absolute inset-0 border-2 border-lime-500/50 rounded-[2.5rem] animate-[spin_4s_linear_infinite]"></div>
        <Clock className="w-10 h-10 text-lime-400 opacity-80" />
      </div>

      <h2 class="industrial-title-xl text-center mb-4">
        SALA DE ESPERA
      </h2>
      
      <p class="industrial-description text-center mb-12 max-w-[280px]">
        Tu profesor está armando los hierros. Aún no tienes una rutina asignada para destrozar.
      </p>

      <button onclick="window.location.reload();" class="w-full bg-white hover:bg-zinc-200 text-black industrial-label py-5 rounded-2xl flex items-center justify-center gap-3 transition-colors active:scale-95 text-base">
        <Dumbbell className="w-5 h-5" />
        Consultar de nuevo
      </button>

      <p class="industrial-metadata mt-8 text-center px-4">
        Avisale a tu profe por WhatsApp que ya bajaste la web
      </p>

    </main>

  </div>
</Layout>
