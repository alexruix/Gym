---
import Layout from '../../layouts/Layout.astro';
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { LogOut, Dumbbell, Clock } from 'lucide-react';

const supabase = getAuthenticatedClient(Astro);
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { data: alumno } = await supabase
  .from('alumnos')
  .select('nombre, plan_id')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();



// Si mágicamente ya le asignaron el plan mientras miraba esto, mandarlo al home
if (alumno?.plan_id) {
  return Astro.redirect('/alumno');
}
---

<Layout title="Preparando motores... - MiGym">
  <div class="min-h-screen bg-black text-white px-6 py-10 flex flex-col relative font-sans overflow-hidden">
    
    <!-- Ambient glows -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-lime-500/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 -right-32 w-[600px] h-[600px] bg-fuchsia-500/10 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="flex justify-between items-center mb-12 relative z-10 w-full max-w-lg mx-auto">
      <div>
        <h1 class="text-3xl font-black tracking-tighter">
          HOLA, <span class="text-lime-500 uppercase">{alumno?.nombre?.split(' ')[0] || 'Alumno'}</span>
        </h1>
      </div>
      
      <form action="/api/auth/signout" method="POST">
        <button type="submit" class="p-3 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800 hover:border-zinc-700 rounded-full transition-all text-zinc-400 hover:text-white group">
          <LogOut className="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" />
        </button>
      </form>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center w-full max-w-lg mx-auto relative z-10">
      
      <div class="w-24 h-24 bg-zinc-900 border border-zinc-800 rounded-[2rem] flex items-center justify-center mb-8 relative animate-pulse">
        <div class="absolute inset-0 border-2 border-lime-500/50 rounded-[2rem] animate-[spin_4s_linear_infinite]"></div>
        <Clock className="w-10 h-10 text-lime-400 opacity-80" />
      </div>

      <h2 class="text-4xl font-black text-center mb-4 tracking-tighter">
        SALA DE ESPERA
      </h2>
      
      <p class="text-zinc-400 text-center mb-12 font-medium max-w-[280px] leading-relaxed">
        Tu profesor está armando los hierros. Aún no tienes una rutina asignada para destrozar.
      </p>

      <button onclick="window.location.reload();" class="w-full bg-white hover:bg-zinc-200 text-black font-black uppercase tracking-widest py-5 rounded-2xl flex items-center justify-center gap-3 transition-colors active:scale-95">
        <Dumbbell className="w-5 h-5" />
        Consultar de nuevo
      </button>

      <p class="text-xs text-zinc-600 font-bold uppercase tracking-widest mt-8 text-center">
        Avisale a tu profe por WhatsApp que ya bajaste la web
      </p>

    </main>

  </div>
</Layout>
