---
import AlumnoLayout from '../../layouts/AlumnoLayout.astro';
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { WaitingRoomContent } from '@/components/organisms/alumno/WaitingRoomContent';
import { esperaCopy } from '@/data/es/alumno/espera';

const supabase = getAuthenticatedClient(Astro);
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { data: _alumnoRaw } = await supabase
  .from('alumnos')
  .select('nombre, plan_id, planes(id)')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

const alumno = _alumnoRaw as any;
const hasPlanRecord = !!alumno?.planes;

// Si mágicamente ya le asignaron el plan mientras miraba esto, mandarlo al home
// Verificamos tanto plan_id como la existencia del registro para evitar bucles de redirección
if (alumno?.plan_id && hasPlanRecord) {
  return Astro.redirect('/alumno');
}

// En este punto alumno puede ser null (sin plan), pero accedemos solo con ?.nombre
const alumnoNombre = alumno?.nombre ?? 'Alumno';
---

<AlumnoLayout title={esperaCopy.pageTitle}>
  <WaitingRoomContent client:load alumnoNombre={alumnoNombre} />
</AlumnoLayout>
