---
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { actions } from 'astro:actions';
import { getDayNumber, getWeekNumber, getTodayISO } from '@/lib/schedule';
import { ActiveSession } from '@/components/organisms/alumno/ActiveSession';
import { SessionDashboardHeader } from '@/components/organisms/alumno/SessionDashboardHeader';
import { StandardPlanView } from '@/components/organisms/alumno/StandardPlanView';
import { sesionStrings } from '@/data/es/alumno/sesion';
import Layout from '@/layouts/Layout.astro';
import AlumnoLayout from '@/layouts/AlumnoLayout.astro';
import { Calendar, ArrowRight, Clock } from 'lucide-react';
import '@/styles/global.css';

const supabase = getAuthenticatedClient(Astro);
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

// 1. Verificar que el alumno tiene plan asignado
const { data: _alumnoRaw } = await supabase
  .from('alumnos')
  .select('id, nombre, fecha_inicio, plan_id, dias_asistencia, turno_id, turnos(id, nombre, hora_inicio, hora_fin), planes(id, nombre, frecuencia_semanal)')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

const alumno = _alumnoRaw as any;

if (!alumno || !alumno.plan_id) {
  return Astro.redirect('/alumno/espera');
}

const hasEmptyAgenda = (alumno.dias_asistencia || []).length === 0;

// 2. Instanciar la sesión de hoy (obtener si existe, crear si no)
let sesion: any = null;
let isRestDay = false;
let planDetails: any = null;

const { data: response, error: errorInst } = await Astro.callAction(actions.alumno.instanciarSesion, {
  fecha_real: getTodayISO(),
});

if (errorInst || !response?.success) {
  console.warn("Día sin sesión programada, activando Vista Blueprint:", errorInst || response?.message);
  isRestDay = true;
  
  // Fetch full plan details for fallback view
  const { data: planRes } = await Astro.callAction(actions.alumno.getPlanDetails, {});
  planDetails = planRes?.data;
} else {
  sesion = response.data.sesion;
}

const fechaInicio = alumno.fecha_inicio || getTodayISO();
const semanaActual = sesion ? (sesion.semana_numero || getWeekNumber(fechaInicio, new Date())) : getWeekNumber(fechaInicio, new Date());

// 3. Mapear a contrato de ActiveSession (si hay sesión)
const sesionBase = sesion ? (sesion.sesion_ejercicios_instanciados || [])
  .sort((a: any, b: any) => a.orden - b.orden)
  .map((ej: any) => ({
    ejercicio_id: ej.ejercicio_id,
    sesion_ejercicio_id: ej.id,
    ejercicio_plan_id: ej.ejercicio_plan_id,
    series: ej.series_plan,
    reps_target: ej.reps_plan,
    peso_plan: ej.peso_plan,
    descanso_seg: ej.descanso_seg || 60,
    completado: ej.completado,
    biblioteca_ejercicios: ej.biblioteca_ejercicios,
  })) : [];

const nombreDia = sesion ? (sesion.nombre_dia || `Día ${sesion.numero_dia_plan}`) : "Mi Rutina";

const studentDataForHud = {
  nombre: alumno.nombre,
  id: alumno.id,
  planName: alumno.planes?.nombre || "Sin plan",
  dias_asistencia: alumno.dias_asistencia || [],
  turno: alumno.turnos
};
---

{hasEmptyAgenda ? (
    <AlumnoLayout title="Configurá tu Agenda - MiGym">
        <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 animate-in fade-in duration-700">
            <div class="w-20 h-20 rounded-[2.5rem] bg-zinc-900 border border-white/5 flex items-center justify-center mb-8 relative">
                <div class="absolute inset-0 bg-lime-400/20 blur-2xl rounded-full animate-pulse" />
                <Calendar className="w-10 h-10 text-lime-400 relative z-10" />
            </div>
            
            <div class="text-center space-y-4 max-w-xs mb-10">
                <h2 class="text-2xl font-black text-white uppercase tracking-tighter italic">
                    Configurá tu Agenda
                </h2>
                <p class="text-xs font-medium text-zinc-500 leading-relaxed">
                    Tu profesor te asignó un plan de <span class="text-lime-400 font-bold">{alumno.planes?.frecuencia_semanal} días</span> por semana, pero aún no elegiste en qué días y turnos vas a entrenar.
                </p>
            </div>

            <a 
                href="/alumno/perfil?edit=fitness" 
                class="group flex items-center gap-4 bg-lime-400 text-black px-8 py-5 rounded-3xl font-black text-[10px] uppercase tracking-widest hover:scale-105 transition-all active:scale-95 shadow-[0_10px_30px_rgba(163,230,53,0.2)]"
            >
                Configurar ahora
                <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
            </a>

            <div class="mt-12 flex items-center gap-2 text-zinc-600">
                <Clock className="w-3 h-3" />
                <span class="text-[9px] font-bold uppercase tracking-widest">Ajuste de SSOT requerido</span>
            </div>
        </div>
    </AlumnoLayout>
) : isRestDay ? (
    <AlumnoLayout title="Mi Plan - MiGym">
        <StandardPlanView client:load planDataRaw={planDetails} />
    </AlumnoLayout>
) : (
    <AlumnoLayout title={`${sesionStrings.header.training} – MiGym`} hideHeader={true}>
        <div class="bg-black text-white antialiased selection:bg-lime-400/30 overflow-x-hidden min-h-screen font-sans bg-grid-alumno pb-64">
            <SessionDashboardHeader 
                client:load
                alumno={studentDataForHud}
                semanaActual={semanaActual}
                nombreDia={nombreDia}
                diaPlan={sesion.numero_dia_plan}
            />

            <main class="w-full h-full p-4">
                <ActiveSession 
                    client:load 
                    sesionBase={sesionBase}
                    sessionId={sesion.id}
                    alumnoId={alumno.id}
                    semanaActual={semanaActual}
                />
            </main>
        </div>
    </AlumnoLayout>
)}

<style is:global>
  .bg-grid-alumno {
    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
