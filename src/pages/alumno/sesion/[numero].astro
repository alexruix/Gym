---
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { actions } from 'astro:actions';
import { getTodayISO } from '@/lib/schedule';
import { ActiveSession } from '@/components/organisms/alumno/ActiveSession';
import { SessionHeader } from '@/components/molecules/alumno/SessionHeader';
import { sesionStrings } from '@/data/es/alumno/sesion';
import Layout from '@/layouts/Layout.astro';
import '@/styles/global.css';

const supabase = getAuthenticatedClient(Astro);
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { numero } = Astro.params;
const sessionOffsetIndex = parseInt(numero || '1') - 1; 

// 1. Obtener datos del alumno
const { data: _alumnoRaw } = await supabase
  .from('alumnos')
  .select('id, nombre, fecha_inicio, plan_id, planes(id, nombre)')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

const alumno = _alumnoRaw as any;

if (!alumno || !alumno.plan_id) {
  return Astro.redirect('/alumno/espera');
}

// 2. Buscar qué rutina corresponde a este índice (Día N)
const { data: _rutinasRaw } = await supabase
  .from('rutinas_diarias')
  .select('id, dia_numero')
  .eq('plan_id', alumno.plan_id)
  .order('dia_numero', { ascending: true });

const rutinasDiarias = (_rutinasRaw || []) as any[];

if (!rutinasDiarias || rutinasDiarias.length === 0) {
  return Astro.redirect('/alumno/espera');
}

// Seleccionamos la rutina (usando módulo si el número excede la cantidad de rutinas)
// Aseguramos que el índice sea positivo para evitar undefined en el array
const safeIndex = Math.max(0, sessionOffsetIndex);
const rutinaActual = rutinasDiarias[safeIndex % rutinasDiarias.length];

if (!rutinaActual) {
  return Astro.redirect('/alumno/espera');
}

// 3. Instanciar la sesión usando la ACCIÓN (Seguridad + Unificación)
// El backend se encarga de resolver JIT y Overrides
const { data: response, error: errorInst } = await Astro.callAction(actions.alumno.instanciarSesion, {
  fecha_real: getTodayISO(),
  rutina_id: rutinaActual.id, // Forzamos esta rutina específica
});

if (errorInst || !response?.success) {
  console.error("Error instanciando sesión por número:", errorInst || response?.message);
  return Astro.redirect('/alumno/espera');
}

const instanciado = response.data;
const sesion = instanciado.sesion;
const nombreDia = sesion.nombre_dia || `Día ${sesion.numero_dia_plan}`;
const semanaActual = sesion.semana_numero || 1;

// 4. Mapear a contrato de ActiveSession
const sesionBase = (sesion.sesion_ejercicios_instanciados || [])
  .sort((a: any, b: any) => a.orden - b.orden)
  .map((ej: any) => ({
    ejercicio_id: ej.ejercicio_id,
    sesion_ejercicio_id: ej.id,
    ejercicio_plan_id: ej.ejercicio_plan_id,
    series: ej.series_plan,
    reps_target: ej.reps_plan,
    peso_plan: ej.peso_plan,
    descanso_seg: ej.descanso_seg || 60,
    completado: ej.completado,
    biblioteca_ejercicios: ej.biblioteca_ejercicios,
  }));
---

<Layout title={`${sesionStrings.header.training} – MiGym`}>
  <div class="bg-black text-white antialiased selection:bg-lime-400/30 overflow-x-hidden min-h-screen font-sans bg-grid-alumno">
    <SessionHeader 
      semanaActual={semanaActual}
      nombreDia={nombreDia}
      diaPlan={sesion.numero_dia_plan}
    />

    <main class="w-full h-full p-4 mt-6">
      <ActiveSession 
        client:load 
        sesionBase={sesionBase}
        sessionId={sesion.id}
        alumnoId={alumno.id}
        semanaActual={semanaActual}
      />
    </main>
  </div>
</Layout>

<style is:global>
  .bg-grid-alumno {
    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
