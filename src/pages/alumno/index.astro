---
import Layout from "../../layouts/Layout.astro";
import { actions } from "astro:actions";
import { formatFechaHumana } from "@/lib/schedule";
import { DayCalendarStrip } from "@/components/molecules/DayCalendarStrip";
import { UpcomingSessionPreview } from "@/components/molecules/UpcomingSessionPreview";
import { PerformanceAnalytics } from "@/components/organisms/alumno/PerformanceAnalytics";
import { TechnicalLabel } from "@/components/atoms/alumno/TechnicalLabel";
import { dashboardStrings } from "@/data/es/alumno/dashboard";
import { Zap, LogOut, TrendingUp, Clock, Calendar } from "lucide-react";
import { cn } from "@/lib/utils";
import '@/styles/global.css';

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

// 1. Fetch consolidado via Action (Seguridad + Sincronización Total)
const { data: response, error } = await Astro.callAction(actions.alumno.getDashboardData, {});

if (error || !response?.success) {
  console.error("Error al cargar dashboard:", error || response?.message);
  return Astro.redirect("/alumno/espera");
}

const { alumno, turno, sesionHoy, proximaSesion, calendarDays, semanaActual, fechaHoyISO } = response.data;

const sesionCompletada = sesionHoy?.estado === "completada";
const fechaHumana = formatFechaHumana(new Date());

// Preparar ejercicios para el preview de hoy
const ejerciciosHoy = sesionHoy?.sesion_ejercicios_instanciados
    ?.sort((a: any, b: any) => a.orden - b.orden)
    ?.slice(0, 3) || [];

// Mapeo para DayCalendarStrip (Asegurar que los tipos coincidan)
const mappedCalendar = calendarDays.map((d: any) => ({
    ...d,
    fechaDisplay: String(new Date(d.fecha + 'T12:00:00').getDate()),
    diaSemana: ["Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb"][new Date(d.fecha + 'T12:00:00').getDay()],
}));

---

<Layout title="Dashboard - MiGym Alumno">
  <div class="min-h-screen bg-black text-white px-5 py-10 overflow-hidden relative font-sans bg-grid-alumno">
    
    <!-- Ambient glows (DSAlumno Style) -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-lime-500/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 -right-32 w-[500px] h-[500px] bg-fuchsia-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Header -->
    <header class="flex justify-between items-start mb-10 relative z-10 w-full max-w-lg mx-auto">
      <div>
        <TechnicalLabel className="text-zinc-500 mb-1">
          {dashboardStrings.header.greeting}
        </TechnicalLabel>
        <h1 class="text-4xl font-black tracking-tighter uppercase leading-none">
          {alumno.nombre.split(" ")[0]}
        </h1>
        <p class="text-zinc-600 font-bold text-[10px] mt-2 uppercase tracking-[0.2em]">
          {alumno.plan_nombre || dashboardStrings.header.noPlan}
        </p>
      </div>

      <div class="flex items-center gap-3">
        <button id="copyLinkBtn" data-email={user.email} class="w-12 h-12 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-lime-400 transition-all active:scale-95 shadow-xl">
          <Zap className="w-5 h-5" />
        </button>
        <form action="/api/auth/signout" method="POST">
          <button type="submit" class="w-12 h-12 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-red-400 transition-all active:scale-95 shadow-xl">
            <LogOut className="w-5 h-5" />
          </button>
        </form>
      </div>
    </header>

    <main class="w-full max-w-lg mx-auto flex flex-col gap-6 relative z-10 pb-20">
      
      <!-- PERFORMANCE ANALYTICS (Impact Stats) -->
      <PerformanceAnalytics client:idle calendarDays={calendarDays} />

      <!-- MI TURNO (Sync Visibility) -->
      <section class="bg-zinc-900/30 border border-white/5 rounded-[2rem] p-6 backdrop-blur-md">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-lime-400 flex items-center justify-center shadow-lg shadow-lime-500/20">
                    <Clock className="w-5 h-5 text-black" />
                </div>
                <div>
                    <TechnicalLabel>{dashboardStrings.shift.title}</TechnicalLabel>
                    <p class="text-lg font-black uppercase tracking-tight">
                        {turno ? `${turno.nombre}` : dashboardStrings.shift.noShift}
                    </p>
                </div>
            </div>
            {turno && (
                <div class="text-right">
                    <p class="text-xl font-black text-lime-400 tabular-nums leading-none">
                        {turno.hora_inicio}
                    </p>
                    <p class="text-[10px] font-bold text-zinc-600 uppercase tracking-widest mt-1">
                        a {turno.hora_fin}
                    </p>
                </div>
            )}
        </div>
      </section>

      <!-- AGENDA / CALENDARIO -->
      <section class="bg-zinc-900/40 border border-white/5 rounded-[2.5rem] p-6 backdrop-blur-xl">
        <div class="flex items-center justify-between mb-6 px-2">
          <div>
            <TechnicalLabel>{dashboardStrings.agenda.title}</TechnicalLabel>
            <p class="text-sm font-bold text-white capitalize mt-1 opacity-60">
              {fechaHumana}
            </p>
          </div>
          <div class="text-right">
            <TechnicalLabel>{dashboardStrings.agenda.week}</TechnicalLabel>
            <p class="text-3xl font-black text-lime-400 leading-none">
              {semanaActual}
            </p>
          </div>
        </div>

        <DayCalendarStrip
          client:idle
          dias={mappedCalendar}
          diaSeleccionado={fechaHoyISO}
        />
      </section>

      <!-- TARJETA SESIÓN ACTUAL -->
      <section class="relative group overflow-hidden bg-zinc-900 border border-zinc-800 rounded-[3rem] p-8 shadow-2xl transition-all hover:border-lime-500/30">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-lime-400/10 rounded-full blur-[60px] pointer-events-none group-hover:bg-lime-400/20 transition-all duration-700"></div>

        <div class="flex items-center justify-between mb-8">
          <div>
            <TechnicalLabel className="text-zinc-500">
                {dashboardStrings.today.dayLabel} {sesionHoy?.numero_dia_plan || "--"} · {dashboardStrings.today.todayLabel}
            </TechnicalLabel>
            <h2 class="text-3xl font-black text-white tracking-tighter mt-1 uppercase leading-none">
              {sesionHoy?.nombre_dia || dashboardStrings.today.noSession}
            </h2>
          </div>
          {sesionCompletada && (
              <div class="flex items-center gap-2 bg-lime-500/10 border border-lime-500/20 px-4 py-2 rounded-full">
                <div class="w-1.5 h-1.5 rounded-full bg-lime-400 animate-pulse"></div>
                <span class="text-[10px] font-bold text-lime-400 uppercase tracking-widest">{dashboardStrings.today.completed}</span>
              </div>
          )}
        </div>

        {ejerciciosHoy.length > 0 && !sesionCompletada && (
            <div class="space-y-4 mb-8">
              {ejerciciosHoy.map((ej: any, idx: number) => (
                <div class="flex items-center gap-4 group/item">
                  <div class={cn(
                    "w-8 h-8 rounded-xl flex items-center justify-center font-bold text-[10px] transition-all",
                    ej.completado ? "bg-lime-400 text-black" : "bg-black border border-white/10 text-zinc-500"
                  )}>
                    {ej.completado ? "✓" : idx + 1}
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class={cn(
                        "font-bold text-sm truncate uppercase tracking-tight",
                        ej.completado ? "text-zinc-600 line-through" : "text-white"
                    )}>
                        {ej.biblioteca_ejercicios?.nombre}
                    </p>
                    <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest mt-0.5">
                        {ej.series_plan} × {ej.reps_plan} {ej.peso_plan ? `@ ${ej.peso_plan}kg` : ""}
                    </p>
                  </div>
                </div>
              ))}
            </div>
        )}

        {/* BOTÓN DE ACCIÓN PRINCIPAL (Premium Glow) */}
        {sesionCompletada ? (
            <a href="/alumno/sesion/hoy" class="flex items-center justify-center gap-3 w-full h-16 bg-zinc-950 border border-zinc-800 rounded-2xl text-zinc-500 font-bold uppercase tracking-widest text-[10px] hover:text-white hover:border-zinc-600 transition-all active:scale-95">
                {dashboardStrings.today.viewSummary}
                <TrendingUp className="w-4 h-4 opacity-50" />
            </a>
        ) : (
            <a href="/alumno/sesion/hoy" class="relative block group/btn active:scale-[0.98] transition-all">
                <div class="absolute inset-0 bg-lime-400 blur-xl opacity-20 group-hover/btn:opacity-40 transition-opacity"></div>
                <div class="relative w-full h-20 bg-lime-400 text-black rounded-[2rem] flex items-center justify-center gap-4">
                    <Zap className="w-6 h-6 fill-black" />
                    <span class="text-xl font-black uppercase tracking-[0.2em]">
                        {sesionHoy ? dashboardStrings.today.continueSession : dashboardStrings.today.startSession}
                    </span>
                </div>
            </a>
        )}
      </section>

      <!-- PRÓXIMA SESIÓN INTELIGENTE -->
      {proximaSesion && (
          <UpcomingSessionPreview 
            client:visible 
            sesion={{
                ...proximaSesion,
                fechaHumana: formatFechaHumana(new Date(proximaSesion.fecha + 'T12:00:00'))
            }} 
          />
      )}

    </main>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById("copyLinkBtn");
  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      const email = (copyBtn as any).dataset.email;
      try {
        const url = `${window.location.origin}/login?email=${encodeURIComponent(email || "")}`;
        await navigator.clipboard.writeText(url);
        // Simple and industrial alert
        alert("LINK COPIADO");
      } catch (err) {
        console.error("Error al copiar:", err);
      }
    });
  }
</script>

<style is:global>
  .bg-grid-alumno {
    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
