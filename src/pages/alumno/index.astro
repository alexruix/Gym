---
import Layout from '../../layouts/Layout.astro';
import { getAuthenticatedClient } from '@/lib/supabase-ssr';
import { PlanGenerator } from '@/lib/plan-generator';
import { Zap, LogOut, Dumbbell } from 'lucide-react';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const supabase = getAuthenticatedClient(Astro);

const { data: alumno } = await supabase
  .from('alumnos')
  .select('id, nombre, fecha_inicio, plan_id, planes(id, nombre)')
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

if (!alumno || !alumno.plan_id) {
  // Redirigir a sala de espera si no tiene plan aún
  return Astro.redirect('/alumno/espera');
}

// Lógica de "Próxima sesión"
const upcomingSessionDay = 1; 

// Fetch para el Spoiler de Hoy
const currentWeek = PlanGenerator.getCurrentWeek(alumno.fecha_inicio || new Date());
const { data: rutinasDiarias } = await supabase
  .from('rutinas_diarias')
  .select('*')
  .eq('plan_id', alumno.plan_id)
  .order('orden', { ascending: true });

let sesionResueltaPreview = [];

if (rutinasDiarias && rutinasDiarias.length > 0) {
  const rutinaActual = rutinasDiarias[upcomingSessionDay - 1]; // Offset index 0
  const diasNombre = ['lunes', 'martes', 'miercoles', 'jueves', 'viernes', 'sabado', 'domingo'];
  const diaNormalizado = rutinaActual.nombre_dia ? rutinaActual.nombre_dia.toLowerCase().trim() : diasNombre[rutinaActual.dia_numero - 1] || 'lunes';

  const { data: ejerciciosPlan } = await supabase
    .from('ejercicios_plan')
    .select(`
      *,
      biblioteca_ejercicios!inner(nombre)
    `)
    .eq('rutina_id', rutinaActual.id)
    .order('orden', { ascending: true });

  const { data: planRotaciones } = await supabase
    .from('plan_rotaciones')
    .select('*')
    .eq('plan_id', alumno.plan_id);

  sesionResueltaPreview = PlanGenerator.resolveSessionExercises(
    (ejerciciosPlan || []) as any[], 
    (planRotaciones || []), 
    currentWeek, 
    diaNormalizado
  ).slice(0, 3); // Solo top 3 para el preview
}
---

<Layout title="Dashboard - MiGym Alumno">
  <div class="min-h-screen bg-black text-white px-6 py-10 overflow-hidden relative font-sans">
    
    <!-- Ambient glows (Glassmorphism + Neon) -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-lime-500/20 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 -right-32 w-[600px] h-[600px] bg-fuchsia-500/10 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="flex justify-between items-center mb-12 relative z-10 w-full max-w-lg mx-auto">
      <div>
        <h1 class="text-3xl font-black tracking-tighter mix-blend-difference">
          HOLA, <span class="text-transparent bg-clip-text bg-gradient-to-r from-lime-400 to-lime-600">{alumno?.nombre?.toUpperCase() || 'ATLETA'}</span>
        </h1>
        <p class="text-zinc-400 font-medium text-sm mt-1 uppercase tracking-widest">PLAN ACTUAL: {alumno?.planes?.nombre || 'General'}</p>
      </div>
      
      <div class="flex items-center gap-2">
        <button 
          id="copyLinkBtn"
          data-email={user.email}
          class="p-4 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800 hover:border-zinc-700 rounded-full transition-all text-zinc-400 hover:text-lime-400 hover:scale-105 active:scale-95 shadow-xl group/copy"
          title="Copiar mi link de acceso"
        >
          <Zap className="w-5 h-5 group-hover/copy:animate-pulse" />
        </button>
        
        <form action="/api/auth/signout" method="POST">
          <button type="submit" class="p-4 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800 hover:border-zinc-700 rounded-full transition-all text-zinc-400 hover:text-white hover:scale-105 active:scale-95 shadow-xl">
            <LogOut className="w-5 h-5" />
          </button>
        </form>
      </div>
    </header>

    <main class="w-full max-w-lg mx-auto mt-20 flex flex-col items-center relative z-10">
      
      <!-- Animated Start Button -->
      <a href={`/alumno/sesion/${upcomingSessionDay}`} class="group relative inline-flex items-center justify-center p-[3px] mb-14 overflow-hidden text-lg font-black rounded-[2.5rem] outline-none">
        <span class="absolute w-full h-full bg-gradient-to-br from-lime-400 via-lime-500 to-fuchsia-600 group-hover:from-lime-400 group-hover:via-lime-600 group-hover:to-fuchsia-500 animate-[spin_4s_linear_infinite] blur-md opacity-100 transition-all duration-20"></span>
        <span class="relative px-12 py-10 transition-all ease-in duration-75 bg-black rounded-[2.3rem] shadow-[inset_0_2px_20px_rgba(255,255,255,0.1)] hover:bg-zinc-950">
          <span class="relative z-10 flex flex-col items-center gap-3">
            <Zap className="w-12 h-12 text-lime-400 drop-shadow-[0_0_15px_rgba(163,230,53,0.8)]" />
            <span class="uppercase tracking-[0.2em] text-lime-400 font-black text-2xl drop-shadow-[0_0_10px_rgba(163,230,53,0.3)]">Entrenar Hoy</span>
          </span>
        </span>
      </a>

      <!-- Preview Inteligente -->
      <div class="w-full bg-zinc-900/60 border border-zinc-800/80 rounded-[2rem] p-7 backdrop-blur-2xl shadow-2xl relative z-10 overflow-hidden">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-lime-500/20 blur-[50px] pointer-events-none"></div>

        <h2 class="text-xs font-black text-zinc-500 uppercase tracking-widest mb-6 px-1 flex items-center gap-2">
          <Dumbbell className="w-4 h-4 text-lime-500" /> Preparación Mental (Spoiler)
        </h2>
        
        <div class="space-y-4">
          {sesionResueltaPreview.length > 0 ? sesionResueltaPreview.map((ej, index) => (
            <div class={`flex items-center justify-between pb-4 ${index !== sesionResueltaPreview.length - 1 ? 'border-b border-white/5' : ''} ${ej.is_variation ? 'border-l-2 pl-4 border-fuchsia-500' : ''}`}>
              <div>
                {ej.is_variation && (
                  <div class="flex items-center gap-2 mb-1">
                    <span class="px-2 py-[2px] bg-fuchsia-500/10 text-fuchsia-400 text-[10px] uppercase font-black tracking-widest rounded-sm border border-fuchsia-500/20">Semana {currentWeek}</span>
                  </div>
                )}
                <p class="font-black text-xl text-white tracking-tight">{ej.biblioteca_ejercicios?.nombre || 'Ejercicio Desconocido'}</p>
                <div class="flex items-center gap-3 mt-1">
                  <span class="bg-zinc-800 text-zinc-300 font-medium text-xs px-2 py-0.5 rounded uppercase tracking-wider">{ej.series} SERIES</span>
                  <span class="text-lime-500/80 font-bold text-sm tracking-wider">× {ej.reps_target}</span>
                </div>
              </div>
            </div>
          )) : (
            <p class="text-zinc-500 text-sm text-center py-4">No hay ejercicios cargados en tu próxima rutina.</p>
          )}
        </div>
        
        {sesionResueltaPreview.length > 0 && (
          <div class="mt-8">
            <a href="/alumno/mi-plan" class="w-full font-black text-sm text-zinc-400 hover:text-white transition-colors uppercase tracking-[0.2em] flex items-center justify-center gap-2 pb-2">
              Ver Plan Completo <span class="text-lime-500">→</span>
            </a>
          </div>
        )}
      </div>

    </main>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById('copyLinkBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const email = copyBtn.getAttribute('data-email');
      try {
        const url = `${window.location.origin}/login?email=${encodeURIComponent(email || '')}`;
        await navigator.clipboard.writeText(url);
        alert('✅ Link de acceso copiado. Guardalo para entrar desde otros dispositivos.');
      } catch (err) {
        console.error('Error al copiar:', err);
      }
    });
  }
</script>
