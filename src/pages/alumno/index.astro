---
import AlumnoLayout from "../../layouts/AlumnoLayout.astro";
import { actions } from "astro:actions";
import { formatFechaHumana } from "@/lib/schedule";
import { DayCalendarStrip } from "@/components/molecules/DayCalendarStrip";
import { UpcomingSessionPreview } from "@/components/molecules/UpcomingSessionPreview";
import { TechnicalLabel } from "@/components/atoms/alumno/TechnicalLabel";
import { dashboardStrings } from "@/data/es/alumno/dashboard";
import { Zap, LogOut, TrendingUp, Clock, Calendar } from "lucide-react";
import { cn } from "@/lib/utils";
import '@/styles/global.css';

import { DashboardRoutinePreview } from "@/components/organisms/alumno/DashboardRoutinePreview";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

// 1. Fetch consolidado via Action (Seguridad + Sincronización Total)
const { data: response, error } = await Astro.callAction(actions.alumno.getDashboardData, {});

if (error || !response?.success) {
  console.error("Error al cargar dashboard:", error || response?.message);
  return Astro.redirect("/alumno/espera");
}

// 1b. Si el plan es nulo
if (!response.data.alumno) return Astro.redirect('/login');
if (!response.data.alumno.has_plan) return Astro.redirect('/alumno/espera');

const { alumno, turno, sesionHoy, routinePreview, proximaSesion, calendarDays, semanaActual, fechaHoyISO } = response.data;

const sesionCompletada = sesionHoy?.estado === "completada";
const fechaHumana = formatFechaHumana(new Date());

// Preparar ejercicios para el preview de hoy
const ejerciciosHoy = sesionHoy?.sesion_ejercicios_instanciados
    ?.sort((a: any, b: any) => a.orden - b.orden)
    ?.slice(0, 3) || [];

// Mapeo para DayCalendarStrip (Asegurar que los tipos coincidan)
const mappedCalendar = calendarDays.map((d: any) => ({
    ...d,
    fechaDisplay: String(new Date(d.fecha + 'T12:00:00').getDate()),
    diaSemana: ["Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb"][new Date(d.fecha + 'T12:00:00').getDay()],
}));

---

<AlumnoLayout title="Dashboard - MiGym Alumno">
  <div class="px-5 pb-24 overflow-hidden relative font-sans bg-grid-alumno">
    
    <!-- Ambient glows (DSAlumno Style) -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-lime-500/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 -right-32 w-[500px] h-[500px] bg-fuchsia-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="flex justify-between items-center mb-10 pt-10 relative z-10 w-full max-w-lg mx-auto">
      <div class="flex flex-col">
        <h1 class="industrial-title-xl">
          {dashboardStrings.header.greeting}{" "}
          <span class="text-lime-500">{alumno.nombre.split(" ")[0]}</span>
        </h1>
        <p class="industrial-description mt-1">{fechaHumana}</p>
      </div>

      <div class="flex items-center gap-3">
        <button id="copyLinkBtn" data-email={user.email} class="w-12 h-12 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-lime-400 transition-all active:scale-95 shadow-xl">
          <Zap className="w-5 h-5" />
        </button>
        <form action="/api/auth/signout" method="POST">
          <button type="submit" class="w-12 h-12 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-red-400 transition-all active:scale-95 shadow-xl">
            <LogOut className="w-5 h-5" />
          </button>
        </form>
      </div>
    </header>

    <main class="w-full max-w-lg mx-auto flex flex-col gap-6 relative z-10 pb-20">
      
      <!-- MI TURNO / AGENDA (Industrial HUD) -->
      <section class="bg-zinc-900/40 border border-white/5 rounded-[2.5rem] p-6 backdrop-blur-xl group overflow-hidden relative">
          <div class="absolute top-0 right-0 w-32 h-32 bg-lime-400/5 blur-[50px] pointer-events-none rounded-full" />
          
          <div class="grid grid-cols-2 gap-6 relative z-10">
              {/* Bloque: Agenda */}
              <div class="space-y-2">
                  <p class="text-[8px] font-black text-zinc-500 uppercase tracking-[0.2em] flex items-center gap-2">
                      <Calendar className="w-3 h-3 text-lime-400" />
                      Agenda
                  </p>
                  <div class="flex flex-col">
                      <p class="text-sm font-black text-white uppercase tracking-tight">
                          {(alumno.dias_asistencia || []).length > 0 
                            ? (alumno.dias_asistencia || []).map((d: string) => d.slice(0, 3).toUpperCase()).join(" - ")
                            : "Sin días"}
                      </p>
                      <!-- <TechnicalLabel className="text-[9px] text-zinc-600 mt-0.5">
                          Agenda
                      </TechnicalLabel> -->
                  </div>
              </div>

              {/* Bloque: Horario */}
              <div class="space-y-2 text-right">
                  <p class="text-[8px] font-black text-zinc-500 uppercase tracking-[0.2em] flex items-center justify-end gap-2">
                      {dashboardStrings.shift.title}
                      <Clock className="w-3 h-3 text-lime-400" />
                  </p>
                  <div class="flex flex-col items-end">
                      <!-- <p class="text-sm font-black text-white uppercase tracking-tight">
                          {turno ? `${turno.nombre}` : dashboardStrings.shift.noShift}
                      </p> -->
                      {turno && (
                          <p class="text-xs font-bold text-lime-400 tabular-nums mt-0.5">
                              {turno.hora_inicio.slice(0, 5)} <span class="text-zinc-600 font-medium tracking-widest text-[9px] uppercase">a</span> {turno.hora_fin.slice(0, 5)}
                          </p>
                      )}
                  </div>
              </div>
          </div>
      </section>

      <!-- AGENDA / CALENDARIO -->
      <section class="bg-zinc-900/40 border border-white/5 rounded-[2.5rem] p-6 backdrop-blur-xl">
        <div class="flex items-center justify-between mb-6 px-2">
          <div>
            <TechnicalLabel>{dashboardStrings.agenda.title}</TechnicalLabel>
            <p class="text-sm font-bold text-white capitalize mt-1 opacity-60">
              {fechaHumana}
            </p>
          </div>
          <div class="text-right">
            <TechnicalLabel>{dashboardStrings.agenda.week}</TechnicalLabel>
            <p class="text-3xl font-black text-lime-400 leading-none">
              {semanaActual}
            </p>
          </div>
        </div>

        <DayCalendarStrip
          client:idle
          dias={mappedCalendar}
          diaSeleccionado={fechaHoyISO}
        />
      </section>

      <!-- CONSOLA DE PREPARACIÓN / RUTINA DEL DÍA -->
      <DashboardRoutinePreview 
        client:load 
        sesionHoy={sesionHoy} 
        routinePreview={routinePreview} 
        alumnoId={alumno.id} 
      />

      <!-- PRÓXIMA SESIÓN INTELIGENTE -->
      {proximaSesion && (
          <UpcomingSessionPreview 
            client:visible 
            sesion={{
                ...proximaSesion,
                fechaHumana: formatFechaHumana(new Date(proximaSesion.fecha + 'T12:00:00'))
            }} 
          />
      )}

    </main>
  </div>
  </div>
</AlumnoLayout>

<script>
  const copyBtn = document.getElementById("copyLinkBtn");
  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      const email = (copyBtn as any).dataset.email;
      try {
        const url = `${window.location.origin}/login?email=${encodeURIComponent(email || "")}`;
        await navigator.clipboard.writeText(url);
        // Simple and industrial alert
        alert("LINK COPIADO");
      } catch (err) {
        console.error("Error al copiar:", err);
      }
    });
  }
</script>

<style is:global>
  .bg-grid-alumno {
    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
