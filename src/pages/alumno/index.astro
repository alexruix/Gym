  const diaCicicoManana = getCyclicDayNumber(diaManana, rutinasDiarias.length);
  const rutinaManana = rutinasDiarias.find((r: any) => r.dia_numero === diaCicicoManana);

  if (rutinaManana) {
    const { data: ejerciciosManana } = await supabase
      .from('ejercicios_plan')
      .select('orden, series, reps_target, biblioteca_ejercicios(nombre)')
      .eq('rutina_id', rutinaManana.id)
      .order('orden', { ascending: true });

    const DIAS_ES = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
    const diaSemanaNombre = DIAS_ES[manana.getDay()];
    const mesNombre = manana.toLocaleDateString('es-AR', { month: 'long' });
    const fechaHumanaManana = `Mañana, ${diaSemanaNombre.charAt(0).toUpperCase() + diaSemanaNombre.slice(1)} ${manana.getDate()} de ${mesNombre}`;

    upcomingSession = {
      fecha: mananaISO,
      fechaHumana: fechaHumanaManana,
      numeroDiaPlan: diaManana,
      semana: getWeekNumber(fechaInicio, manana),
      nombreDia: rutinaManana.nombre_dia || `Día ${diaManana}`,
      ejercicios: (ejerciciosManana || []).map((ej: any) => {
        const bib = Array.isArray(ej.biblioteca_ejercicios) ? ej.biblioteca_ejercicios[0] : ej.biblioteca_ejercicios;
        return {
          nombre: bib?.nombre || 'Ejercicio',
          series_plan: ej.series,
          reps_plan: ej.reps_target,
        };
      }),
    };
  }
