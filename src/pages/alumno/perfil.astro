---
import AlumnoLayout from "../../layouts/AlumnoLayout.astro";
import { getAuthenticatedClient } from "@/lib/supabase-ssr";
import { ProfileContainer } from "../../components/organisms/alumno/profile/ProfileContainer";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const supabase = getAuthenticatedClient(Astro);

// Fetch data from supabase including profesor details and current shift
const { data: alumnoData, error } = await supabase
  .from("alumnos")
  .select(`
    *,
    profesores:profesor_id (
      nombre,
      telefono,
      email,
      gym_nombre
    ),
    turno:turnos!turno_id (*),
    planes:plan_id (frecuencia_semanal)
  `)
  .or(`id.eq.${user.id},user_id.eq.${user.id}`)
  .single();

if (error || !alumnoData) {
  return Astro.redirect("/login");
}

// Fetch all available shifts from the professor for selection
const { data: turnosData } = await supabase
  .from("turnos")
  .select("*")
  .eq("profesor_id", (alumnoData as any).profesor_id)
  .order("hora_inicio", { ascending: true });

// Fetch current occupancy per shift for this professor
const { data: occupancyRaw } = await supabase
  .from("alumnos")
  .select("turno_id")
  .eq("profesor_id", (alumnoData as any).profesor_id)
  .not("turno_id", "is", null);

const occupancyMap: Record<string, number> = {};
occupancyRaw?.forEach(row => {
   if ((row as any).turno_id) {
     occupancyMap[(row as any).turno_id] = (occupancyMap[(row as any).turno_id] || 0) + 1;
   }
});

const alumno = alumnoData as any;
const profesor = alumno.profesores;
const turnos = turnosData || [];
const maxDays = alumno.planes?.frecuencia_semanal || alumno.frecuencia_semanal || 0;
---

<AlumnoLayout title="Mi Perfil - MiGym Alumno">
  <div class="pt-6 relative z-10 w-full animate-in fade-in slide-in-from-bottom-4 duration-500">
    <header class="mb-8">
      <h1 class="industrial-title-lg mb-2 text-white text-3xl">Mi perfil</h1>
      <p class="industrial-metadata tracking-[0.2em] opacity-60">Gestioná tus datos personales y ficha física.</p>
    </header>

    <main>
      <ProfileContainer 
        client:load 
        alumno={alumno} 
        profesor={profesor} 
        turnos={turnos}
        occupancyMap={occupancyMap}
        maxDays={maxDays}
      />
    </main>
  </div>
</AlumnoLayout>
