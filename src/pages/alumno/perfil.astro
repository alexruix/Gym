---
import AlumnoLayout from '../../layouts/AlumnoLayout.astro';

const user = Astro.locals.user;
if (user?.role === "invitado") {
  return Astro.redirect("/login?error=auth_required_for_profile");
}
---

<AlumnoLayout title="Mi Perfil - MiGym">
  <div class="min-h-screen p-6">
    <h1 class="text-2xl font-bold text-center">Perfil</h1>
  </div>
</AlumnoLayout>
