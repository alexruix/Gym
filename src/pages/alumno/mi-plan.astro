---
import AlumnoLayout from '../../layouts/AlumnoLayout.astro';
import { actions } from 'astro:actions';
import { TechnicalLabel } from '@/components/atoms/alumno/TechnicalLabel';
import { Dumbbell, Scroll, Play, ChevronRight, Hash } from 'lucide-react';
import { planData } from '@/data/es/alumno';
import { cn } from '@/lib/utils';
import '@/styles/global.css';

const { data: response, error } = await Astro.callAction(actions.alumno.getPlanDetails, {});

if (error || !response?.success) {
    console.error("Error cargando plan:", error || response?.message);
}

const plan = response?.data as any;
const rutinas = (plan?.rutinas_diarias || []).sort((a: any, b: any) => a.dia_numero - b.dia_numero);

---

<AlumnoLayout title={`${planData.header.title} - MiGym`}>
  <div class="flex flex-col gap-8 pb-32">
    
    <!-- HEADER INDUSTRIAL -->
    <header class="mb-4">
        <TechnicalLabel className="text-zinc-500 mb-1">{planData.header.label}</TechnicalLabel>
        <h1 class="text-4xl font-black tracking-tighter uppercase leading-none">
            {planData.header.title}
        </h1>
        {plan?.descripcion && (
            <p class="text-xs font-medium text-zinc-500 mt-4 leading-relaxed max-w-sm">
                {plan.descripcion}
            </p>
        )}
    </header>

    <!-- PLAN METADATA -->
    <div class="flex gap-4">
        <div class="flex-1 bg-zinc-900/40 border border-white/5 p-4 rounded-2xl backdrop-blur-md flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-zinc-800 flex items-center justify-center">
                <Hash className="w-4 h-4 text-zinc-400" />
            </div>
            <div>
                <p class="text-[8px] font-bold text-zinc-600 uppercase tracking-widest">{planData.metadata.duration.label}</p>
                <p class="text-sm font-black">{plan?.duracion_semanas || 0} {planData.metadata.duration.unit}</p>
            </div>
        </div>
        <div class="flex-1 bg-zinc-900/40 border border-white/5 p-4 rounded-2xl backdrop-blur-md flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-zinc-800 flex items-center justify-center">
                <Dumbbell className="w-4 h-4 text-zinc-400" />
            </div>
            <div>
                <p class="text-[8px] font-bold text-zinc-600 uppercase tracking-widest">{planData.metadata.frequency.label}</p>
                <p class="text-sm font-black">{plan?.frecuencia_semanal || 0} {planData.metadata.frequency.unit}</p>
            </div>
        </div>
    </div>

    {/* RUTINAS EXPLORER */}
    <div class="space-y-10">
        {rutinas.map((rutina: any) => (
            <section class="space-y-6">
                <div class="flex items-center gap-4 px-2">
                    <div class="w-12 h-12 rounded-[1.25rem] bg-lime-400 text-black flex items-center justify-center font-black text-xl shadow-lg shadow-lime-500/10">
                        {rutina.dia_numero}
                    </div>
                    <div>
                        <h2 class="text-2xl font-black uppercase tracking-tight text-white leading-none">
                            {rutina.nombre_dia || `Día ${rutina.dia_numero}`}
                        </h2>
                        <TechnicalLabel className="mt-1">
                            {(rutina.ejercicios_plan?.length || 0)} {planData.routines.movementsLabel}
                        </TechnicalLabel>
                    </div>
                </div>

                <div class="space-y-3">
                    {rutina.ejercicios_plan?.sort((a: any, b: any) => a.orden - b.orden).map((ej: any, idx: number) => (
                        <div class="group bg-zinc-900/40 border border-white/5 rounded-3xl p-6 hover:bg-zinc-900/60 transition-all hover:border-lime-500/20">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex gap-4 min-w-0">
                                    <div class="w-10 h-10 rounded-xl bg-zinc-950 border border-white/5 flex items-center justify-center text-zinc-600 font-bold text-[10px] shrink-0">
                                        {String(idx + 1).padStart(2, '0')}
                                    </div>
                                    <div class="min-w-0">
                                        <h3 class="text-base font-black text-white uppercase tracking-tight truncate">
                                            {ej.biblioteca_ejercicios?.nombre}
                                        </h3>
                                        <div class="flex items-center gap-3 mt-1">
                                            <span class="text-[10px] font-bold text-lime-400 uppercase tracking-widest">
                                                {ej.series}×{ej.reps_target}
                                            </span>
                                            <div class="w-1 h-1 rounded-full bg-zinc-800" />
                                            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
                                                {ej.peso_target || planData.routines.exerciseStatus.unspecifiedWeight}kg
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                {ej.biblioteca_ejercicios?.media_url && (
                                    <button class="w-10 h-10 rounded-full bg-zinc-800 flex items-center justify-center text-zinc-400 hover:text-white transition-colors shrink-0">
                                        <Play className="w-4 h-4 fill-current" />
                                    </button>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        ))}
    </div>

    {/* Footer Link / Info */}
    <div class="mt-8 p-12 border-2 border-dashed border-zinc-900 rounded-[3rem] flex flex-col items-center gap-4 text-center">
        <Scroll className="w-10 h-10 text-zinc-800" />
        <p class="text-[10px] font-bold text-zinc-700 uppercase tracking-[0.2em] leading-relaxed">
            {planData.footer.message}
        </p>
    </div>

  </div>
</AlumnoLayout>

  </div>
</AlumnoLayout>
