---
import Layout from '../layouts/Layout.astro';
import { authContent } from '../data/authContent';
import Hero from '../components/organisms/landing/Hero.astro';
import SocialProof from '../components/organisms/landing/SocialProof.astro';
import Features from '../components/organisms/landing/Features.astro';
import Testimonials from '../components/organisms/landing/Testimonials.astro';
import Pricing from '../components/organisms/landing/Pricing.astro';
import CtaFinal from '../components/organisms/landing/CtaFinal.astro';
---

<Layout title={authContent.title}>
	<main class="min-h-screen bg-white text-zinc-950 selection:bg-lime-200 lg:overflow-x-hidden">
		<Hero />
		<SocialProof />
		<Features />
		<Testimonials />
		<Pricing />
		<CtaFinal />
		
		<footer class="py-12 border-t border-zinc-900 text-center bg-zinc-950 text-white relative z-10">
			<div class="font-black text-xl tracking-tighter mb-4">
				MI<span class="text-lime-500">GYM</span>
			</div>
			<p class="text-zinc-500 text-xs font-bold uppercase tracking-widest">
				{authContent.footer.copy}
			</p>
		</footer>
	</main>
</Layout>
