---
import Layout from '../layouts/Layout.astro';
import { authContent } from '../data/authContent';
import { 
  Zap, 
  Target, 
  TrendingUp, 
  ShieldCheck 
} from 'lucide-react';

const features = [
  { 
    title: "Planes Inteligentes", 
    desc: "Crea rutinas en segundos usando tus templates de Excel.", 
    icon: Target,
    color: "bg-lime-100 text-lime-700"
  },
  { 
    title: "Seguimiento Realtime", 
    desc: "Vete lo que tus alumnos entrenan en el momento.", 
    icon: Zap,
    color: "bg-sky-100 text-sky-700" 
  },
  { 
    title: "Progreso Visual", 
    desc: "Gráficos de carga y volumen automáticos para cada alumno.", 
    icon: TrendingUp,
    color: "bg-zinc-100 text-zinc-900"
  },
  { 
    title: "Pagos Controlados", 
    desc: "Alertas automáticas de vencimiento. Chau morosos.", 
    icon: ShieldCheck,
    color: "bg-orange-100 text-orange-700"
  }
];
---

<Layout title={authContent.title}>
	<main class="min-h-screen bg-white text-zinc-950 selection:bg-lime-200">
		<!-- Hero Section -->
		<section class="relative pt-20 pb-16 px-6 overflow-hidden border-b border-zinc-100">
			<div class="max-w-5xl mx-auto text-center space-y-8 relative z-10">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-950 text-white text-[10px] font-extrabold tracking-widest uppercase">
					<span class="w-2 h-2 rounded-full bg-lime-400 animate-pulse"></span>
					{authContent.tagline}
				</div>
				
				<h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.9] uppercase">
					Gestioná tu <span class="text-lime-500 italic">gym</span><br/> sin estrés
				</h1>
				
				<p class="text-xl md:text-2xl text-zinc-500 font-bold max-w-2xl mx-auto leading-tight tracking-tight">
					{authContent.landing.heroDescription}
				</p>

				<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
					<a 
						href="/login"
						class="w-full sm:w-auto px-10 h-16 flex items-center justify-center bg-zinc-950 text-white font-black rounded-2xl transition-all hover:bg-zinc-800 active:scale-95 text-lg uppercase tracking-wider group"
					>
						{authContent.landing.ctaPrimario}
						<Zap className="ml-2 w-5 h-5 text-lime-400 group-hover:scale-110 transition-transform" />
					</a>
					<a 
						href="/login"
						class="w-full sm:w-auto px-10 h-16 flex items-center justify-center border-2 border-zinc-200 bg-white text-zinc-950 font-black rounded-2xl transition-all hover:bg-zinc-50 active:scale-95 text-lg uppercase tracking-wider"
					>
						{authContent.landing.ctaSecundario}
					</a>
				</div>
			</div>

			<!-- Decorative element -->
			<div class="absolute -top-40 -right-40 w-96 h-96 bg-lime-400/10 rounded-full blur-3xl opacity-50"></div>
			<div class="absolute -bottom-40 -left-40 w-96 h-96 bg-sky-400/10 rounded-full blur-3xl opacity-50"></div>
		</section>

		<!-- Features Grid -->
		<section class="max-w-6xl mx-auto py-24 px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				{features.map((f) => {
					const Icon = f.icon;
					return (
						<div class="p-8 rounded-3xl border border-zinc-200 bg-zinc-50/50 hover:bg-white hover:border-zinc-300 transition-all group">
							<div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 shadow-inner ${f.color}`}>
								<Icon className="w-7 h-7" />
							</div>
							<h3 class="text-xl font-black uppercase tracking-tight mb-2 group-hover:text-lime-600 transition-colors">
								{f.title}
							</h3>
							<p class="text-zinc-500 font-semibold leading-relaxed">
								{f.desc}
							</p>
						</div>
					)
				})}
			</div>
		</section>

		<footer class="py-12 border-t border-zinc-100 text-center">
			<div class="font-black text-xl tracking-tighter mb-4">
				MI<span class="text-lime-500">GYM</span>
			</div>
			<p class="text-zinc-400 text-xs font-bold uppercase tracking-widest">
				{authContent.footer.copy}
			</p>
		</footer>
	</main>
</Layout>
